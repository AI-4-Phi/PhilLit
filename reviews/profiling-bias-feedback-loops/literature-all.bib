  POSITION: Expressive and comparative-advantage theory of discrimination's wrongness.
  },
  keywords = {discrimination, wrongness, comparative-advantage, Medium, INCOMPLETE, no-abstract}
}

@book{schauer2009profiles,
  author = {Schauer, Frederick},
  title = {Profiles, Probabilities, and Stereotypes},
  publisher = {Harvard University Press},
  year = {2009},
  doi = {10.2307/j.ctvjz82xm},
  note = {
  CORE ARGUMENT: Schauer defends the general rationality of generalisation-based reasoning -- including profiling -- arguing that treating individuals as instances of categories is epistemically unavoidable and often beneficial. He distinguishes between legitimate statistical generalisations and morally objectionable stereotypes by focusing on the accuracy of the underlying generalisation and the moral status of the characteristic being used as a proxy.

