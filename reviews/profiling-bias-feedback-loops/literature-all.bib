  abstract = {NOTES ON THE THEORY OF ASSOCIATION OF ATTRIBUTES IN STATISTICS Get access G. UNDY YULE G. UNDY YULE Search for other works by this author on: Oxford Academic Google Scholar Biometrika, Volume 2, Issue 2, February 1903, Pages 121–134, https://doi.org/10.1093/biomet/2.2.121 Published: 01 February 1903},
  abstract_source = {openalex},
}

@article{blyth1972simpsons,
  author    = {Blyth, Colin R.},
  title     = {On {Simpson's} Paradox and the Sure-Thing Principle},
  journal   = {Journal of the American Statistical Association},
  year      = {1972},
  volume    = {67},
  number    = {338},
  pages     = {364--366},
  doi       = {10.1080/01621459.1972.10482387},
  note      = {
  CORE ARGUMENT: Blyth introduces the name "Simpson's paradox" and
  demonstrates that the paradox violates Savage's Sure-Thing Principle:
  if action A is preferable to B in every subpopulation, it should be
  preferable overall -- yet the paradox yields cases where the
  aggregate favours B. He provides concrete numerical examples
  illustrating how population-mixing reverses the per-stratum direction.

  RELEVANCE: Establishes the decision-theoretic stakes of the paradox:
  agents who aggregate over a third variable risk acting against their
  own interests in each identifiable subpopulation. In the profiling
  context, this corresponds to an official whose aggregate hit-rate
  statistic is a poor guide to any subgroup's actual risk profile.

  POSITION: Statistical framing emphasising normative (decision-
  theoretic) consequences.
  },
  keywords  = {simpsons-paradox, sure-thing-principle, decision-theory, foundational, High},
  abstract = {Abstract This paradox is the possibility of P(A|B) <P(A|B') even though P(A|B)≥P(A| B') both under the additional condition C and under the complement C' of that condition. Details are given on why this can happen and how extreme the inequalities can be. An example shows that Savage's sure-thing principle (“If you would definitely prefer g to f, either knowing that the event C obtained, or knowing that C did not obtain, then you definitely prefer g to f.”) is not applicable to alternatives f and g that involve sequential operations.},
  abstract_source = {openalex},
}

@article{otte1985probabilistic,
  author    = {Otte, Richard},
  title     = {Probabilistic Causality and {Simpson's} Paradox},
  journal   = {Philosophy of Science},
  year      = {1985},
  volume    = {52},
  number    = {1},
  pages     = {110--125},
  doi       = {10.1086/289225},
  note      = {
  CORE ARGUMENT: Otte argues that Simpson's paradox poses a serious
  problem for probabilistic theories of causation (specifically the
  Suppes-style view that C causes E if C raises the probability of E
  in all "causally homogeneous" background contexts). He examines
  several proposed criteria for selecting the relevant partition and
  concludes that no purely probabilistic criterion adequately resolves
  the paradox without importing causal assumptions.

  RELEVANCE: Directly addresses the theoretical question of whether
  group-level statistics carry causal import. The profiling scenario
  is precisely one in which decision-makers treat a spurious aggregate
  association as a causal signal; Otte's analysis explains why such
  inferences require prior causal information not recoverable from the
  statistics alone.

  POSITION: Probabilistic causation view, sceptical that the paradox
  can be resolved without causal background knowledge.
  },
  sep_context = {Cited in SEP "paradox-simpson" bibliography as a foundational philosophical treatment of the paradox in relation to probabilistic causation.},
  keywords  = {simpsons-paradox, probabilistic-causation, confounding, philosophy-of-science, High},
  abstract = {This paper discusses Simpson's paradox and the problem of positive relevance in probabilistic causality. It is argued that Cartwright's solution to Simpson's paradox fails because it ignores one crucial form of the paradox. After clarifying different forms of the paradox, it is shown that any adequate solution to the paradox must allow a cause to be both a negative cause and a positive cause of the same effect. A solution is then given that can handle the form of the paradox that Cartwright's solution ignored, and allows causes to be both a positive and a negative cause of an effect.},
  abstract_source = {openalex},
}

@article{cartwright1979causal,
  author    = {Cartwright, Nancy},
  title     = {Causal Laws and Effective Strategies},
  journal   = {No\^{u}s},
  year      = {1979},
  volume    = {13},
  number    = {4},
  pages     = {419--437},
  doi       = {10.2307/2215337},
  note      = {
  CORE ARGUMENT: Cartwright argues that causal laws underpin effective
  strategies in a way that mere statistical regularities cannot. She
  introduces the slogan "no causes in, no causes out" to challenge
  probabilistic accounts of causality that operate purely on observational
  correlations. Causal relationships cannot be read off association
  measures without independent causal information about the context.

  RELEVANCE: Provides the philosophical grounding for why the official
  in the profiling scenario cannot legitimately infer a causal story
  (group membership causes behaviour) from the observed hit rates.
  The observed correlation is consistent with multiple causal graphs,
  and the one that generates it (poverty as common cause) points away
  from the proposed causal story.

  POSITION: Interventionist/capacity-based theory of causation;
  sceptical of purely probabilistic approaches.
  },
  keywords  = {causation, confounding, probabilistic-causation, interventionism, High},
  abstract = {There are at least two kinds of laws of nature: laws of association and causal laws.1 Laws of association are the faimilar laws with which philosophers usually deal. These laws tell how often two qualities or quantities are co-associated. They may be either deterministic-the association is universal-or probabilistic. equations of physics are a good example: whenever the force on a classical particle of mass m is f the acceleration isf/m. Laws of association may be time indexed, as in the probabilistic laws of Mendelian genetics, but apart from the asymmetries imposed by time indexing, these laws are causally neutral. They tell how often two qualities co-occur; but they provide no account of what makes things happen. Causal laws, by contrast, have the word cause-or some causal surrogate, right in them. Smoking causes lung cancer; perspiration attracts wood ticks; or,-for an example from physics, force causes change in motion: to quote Einstein and Infeld ([5]: 9), The action of an external force changes the velocity... such a force either increases or decreases the velocity according to whether it acts in the direction of motion or in the opposite direction. Bertrand Russell [9] argued that laws of association are all the laws there are, and that causal principles cannot be derived from the causally symmetric laws of association. I shall here argue in support of Russell's second claim, but against the first. Causal principles cannot be reduced to laws of association; but they cannot be done away with. argument in support of causal laws relies on some facts about strategies. They are illustrated in a letter which I recently received from TIAA-CREF, a company which provides insurance for college teachers. letter begins:},
  abstract_source = {openalex},
}

@book{pearl2009causality,
  author    = {Pearl, Judea},
  title     = {Causality},
  publisher = {Cambridge University Press},
  year      = {2009},
  doi       = {10.1017/cbo9780511803161},
  note      = {
  CORE ARGUMENT: Pearl develops the structural causal model (SCM)
  framework, establishing that causal relationships require a language
  distinct from probability -- namely, do-calculus and counterfactual
  reasoning. Chapter 6 ("Simpson's Paradox, Confounding, and
  Collapsibility") provides the definitive causal-graphical treatment
  of the paradox: whether to use aggregated or stratified data depends
  on whether Z is a confounder (common cause of both X and Y,
  requiring adjustment) or a collider (common effect, where
  conditioning introduces spurious correlation).

  RELEVANCE: The DAG framework in this book is the theoretical
  backbone for diagnosing the profiling scenario. Poverty (Z) is a
  confounder of group membership (X) and behaviour (Y); the
  official's failure to condition on Z means the aggregate hit rate
  conflates the causal effect of group membership with the confounding
  influence of poverty.

  POSITION: Causal-graphical/interventionist; the authoritative
  reference for DAG-based resolution of Simpson's paradox.
  },
  keywords  = {causal-inference, DAG, confounding, simpsons-paradox, do-calculus, High},
  abstract = {Written by one of the preeminent researchers in the field, this book provides a comprehensive exposition of modern analysis of causation. It shows how causality has grown from a nebulous concept into a mathematical theory with significant applications in the fields of statistics, artificial intelligence, economics, philosophy, cognitive science, and the health and social sciences. Judea Pearl presents and unifies the probabilistic, manipulative, counterfactual, and structural approaches to causation and devises simple mathematical tools for studying the relationships between causal connections and statistical associations. Cited in more than 2,100 scientific publications, it continues to liberate scientists from the traditional molds of statistical thinking. In this revised edition, Judea Pearl elucidates thorny issues, answers readers' questions, and offers a panoramic view of recent advances in this field of research. Causality will be of interest to students and professionals in a wide variety of fields. Dr Judea Pearl has received the 2011 Rumelhart Prize for his leading research in Artificial Intelligence (AI) and systems from The Cognitive Science Society.},
  abstract_source = {openalex},
}

@article{pearl2014understanding,
  author    = {Pearl, Judea},
  title     = {Comment: {Understanding Simpson's Paradox}},
  journal   = {The American Statistician},
  year      = {2014},
  volume    = {68},
  number    = {1},
  pages     = {8--13},
  doi       = {10.1080/00031305.2014.876829},
  note      = {
  CORE ARGUMENT: Pearl argues that the paradox is neither a mathematical
  curiosity nor a statistical error but a symptom of the inadequacy of
  purely probabilistic reasoning for causal questions. He identifies
  three causal graph structures that give rise to the paradox and argues
  that in each case the correct choice of aggregated vs. disaggregated
  statistic is determined by the causal graph, not by any purely
  statistical criterion. He defends this view against Armistead's
  critique by distinguishing evidential from causal queries.

  RELEVANCE: Offers the most directly applicable causal-graphical
  diagnosis for the profiling scenario: the aggregate hit rate is
  "wrong" because it is calculated from a graph in which the
  confounding path (via poverty) has not been blocked. This paper is
  cited in SEP section 4 as the central contemporary defence of the
  causal interpretation.

  POSITION: Causal-graphical; explicit rebuttal of statistical-only
  approaches to resolving the paradox.
  },
  sep_context = {Cited in SEP paradox-simpson section 4 ("What Makes Simpson's Paradox Paradoxical?") as presenting "several reasons supporting his analysis of the paradox," including the argument that only a causal semantics can account for the paradox's enduring difficulty.},
  keywords  = {simpsons-paradox, causal-inference, confounding, DAG, High},
  abstract = {Click to increase image sizeClick to decrease image size This article is part of the following collections: Teaching Simpson’s Paradox, Confounding, and Causal Inference},
  abstract_source = {openalex},
}

@article{armistead2014resurrecting,
  author    = {Armistead, Timothy W.},
  title     = {Resurrecting the Third Variable: {A} Critique of {Pearl's} Causal Analysis of {Simpson's Paradox}},
  journal   = {The American Statistician},
  year      = {2014},
  volume    = {68},
  number    = {1},
  pages     = {1--7},
  doi       = {10.1080/00031305.2013.807750},
  note      = {
  CORE ARGUMENT: Armistead challenges Pearl's claim that whether to
  condition on a third variable should be determined solely by its
  causal status. He argues that noncausal third variables can carry
  critical information about study design, hidden confounders, and
  data reliability, and that any variable producing a Simpson's
  reversal warrants investigation, regardless of its causal role.

  RELEVANCE: In the profiling context, Armistead's position
  corresponds to the view that even if the official has the wrong
  causal story, the empirical reversal upon stratification by income
  (or another correlate) should trigger reassessment. This
  strengthens the argument that the omission of income is not just
  causally but epistemically unjustified.

  POSITION: Dissent from causal-only resolution; argues for a
  broader evidential rationale for conditioning.
  },
  keywords  = {simpsons-paradox, confounding, variable-selection, causal-inference, Medium},
  abstract = {Pearl argued that Simpson's Paradox would not be considered paradoxical but for statisticians' unwillingness to acknowledge the role of causality in resolving an instance of it. He proposed using a causal calculus to determine which set of contradictory findings in an instance of the paradox should be accepted-the aggregated data or the data disaggregated by conditioning on the third variable. Pearl used the example of a hypothetical quasi-experiment to argue that when third variables are not causal, one should not condition on them, and-assuming no other sources of confounding-the aggregated data should be accepted. Pearl was precipitate in his argument that it would be inappropriate to condition on the noncausal third variables in the example. Whether causal or not, third variables can convey critical information about a first-order relationship, study design, and previously unobserved variables. Any conditioning on a nontrivial third variable that produces Simpson's Paradox should be carefully examined before either the aggregated or the disaggregated findings are accepted, regardless of whether the third variable is thought to be causal. In some cases, neither set of data is trustworthy; in others, both convey information of value. Pearl's hypothetical example is used to illustrate this argument.},
  abstract_source = {openalex},
}

@article{bandyopadhyay2011logic,
  author    = {Bandyoapdhyay, Prasanta S. and Nelson, Davin and Greenwood, Mark and Brittan, Gordon and Berwald, Jesse},
  title     = {The Logic of {Simpson's} Paradox},
  journal   = {Synthese},
  year      = {2010},
  volume    = {181},
  number    = {2},
  pages     = {185--208},
  doi       = {10.1007/s11229-010-9797-0},
  note      = {
  CORE ARGUMENT: The authors decompose Simpson's paradox into three
  analytically separable questions: (i) its mathematical conditions,
  (ii) its logical structure in terms of probability theory, and (iii)
  the normative question of which statistic to use in practice. They
  argue the third question cannot be settled by logic or probability
  alone, and they explicitly bracket it -- concluding that the choice
  between aggregate and disaggregate statistics is context-dependent
  and requires extra-statistical judgment.

  RELEVANCE: Supplies the logical skeleton for the claim that the
  official's use of the aggregate hit rate cannot be justified on
  statistical grounds alone -- an extra assumption about the causal
  or policy context is always required.

  POSITION: Logic/probability-theoretic framing; agnostic about
  which statistic to use, contra Pearl's causal resolution.
  },
  keywords = {simpsons-paradox, logic, probability, aggregation, Medium, INCOMPLETE, no-abstract}
}

@article{fitelson2017confirmation,
  author    = {Fitelson, Branden},
  title     = {{CONFIRMATION, CAUSATION, AND SIMPSON'S PARADOX}},
  journal   = {Episteme},
  year      = {2017},
  volume    = {14},
  number    = {3},
  pages     = {297--309},
  doi       = {10.1017/epi.2017.25},
  note      = {
  CORE ARGUMENT: Fitelson proposes that the paradox is grounded in
  an ambiguity between two readings of confirmation: the suppositional
  reading ("E confirms H given background K") and the conjunctive
  reading ("E-and-K confirms H"). Association reversals are logically
  possible on the suppositional reading but impossible on the conjunctive
  reading. Reasoners are misled because they conflate the two readings
  when evaluating evidence from sub-populations vs. the whole.

  RELEVANCE: Provides a Bayesian epistemic mechanism for why decision-
  makers can simultaneously hold (reasonably, under one reading) that
  within each income stratum group membership is not predictive, while
  also believing (under a different reading) that it is predictive
  overall. This models the cognitive structure of biased statistical
  reasoning.

  POSITION: Bayesian confirmation-theoretic; offers an epistemic rather
  than purely causal explanation of the paradox.
  },
  sep_context = {Cited in SEP paradox-simpson section 4 as proposing a "confirmation-theoretic explanation of Simpson's Paradox" based on distinguishing suppositional from conjunctive readings of confirmation statements.},
  keywords  = {simpsons-paradox, bayesian-confirmation, episteme, probability, High},
  abstract = {ABSTRACT In this paper, I review some recent treatments of Simpson's Paradox, and I propose a new rationalizing explanation of its (apparent) paradoxicality.},
  abstract_source = {openalex},
}

@article{good1987amalgamation,
  author    = {Good, I. J. and Mittal, Y.},
  title     = {The Amalgamation and Geometry of Two-by-Two Contingency Tables},
  journal   = {The Annals of Statistics},
  year      = {1987},
  volume    = {15},
  number    = {2},
  doi       = {10.1214/aos/1176350369},
  note      = {
  CORE ARGUMENT: Good and Mittal provide a geometric characterisation
  of when the amalgamation of 2x2 contingency tables reverses the
  direction of association. They identify the necessary and sufficient
  conditions in terms of weighted averages and show that the reversal
  arises when the weighting differs systematically between the two
  sub-tables -- a condition that obtains when group membership and
  stratum membership are correlated.

  RELEVANCE: Supplies the mathematical precision behind the claim that
  the profiling feedback loop structurally satisfies the conditions for
  Simpson's reversal: because the targeted group is disproportionately
  poor (stratum membership correlated with group membership), the
  aggregate rate is guaranteed to overstate the group-level effect.

  POSITION: Mathematical/statistical; gives the algebraic conditions
  for the reversal without causal interpretation.
  },
  keywords  = {simpsons-paradox, contingency-tables, aggregation, mathematics, Medium},
  abstract = {If a pair of two-by-two contingency tables are amalgamated by addition it can happen that a measure of association for the amalgamated table lies outside the interval between the association measures of the individual tables. We call this the amalgamation paradox and we show how it can be avoided by suitable designs of the sampling experiments. We also study the conditions for the "homogeneity" of two subpopulations with respect to various measures of association. Some of the proofs have interesting geometrical interpretations.},
  abstract_source = {openalex},
}

@article{bickel1975sex,
  author    = {Bickel, P. J. and Hammel, E. A. and O'Connell, J. W.},
  title     = {Sex Bias in Graduate Admissions: {Data} from {Berkeley}},
  journal   = {Science},
  year      = {1975},
  volume    = {187},
  number    = {4175},
  pages     = {398--404},
  doi       = {10.1126/science.187.4175.398},
  note      = {
  CORE ARGUMENT: The Berkeley admissions data showed a large aggregate
  bias against women applicants; disaggregating by department reversed
  or eliminated the apparent bias, because women disproportionately
  applied to more competitive departments. The paper demonstrates how
  structural features of the population (differential application rates
  across subgroups) generate a spurious aggregate disparity with no
  discrimination at the department level.

  RELEVANCE: The canonical real-world instance of Simpson's paradox in
  an institutional discrimination context. The structure is directly
  analogous to the profiling scenario: an aggregate disparity
  (hit rate by group) is explained by a confounding structural variable
  (department choice / income stratum), not by direct discrimination.
  The case illustrates the normative and legal stakes of ignoring the
  confound.

  POSITION: Applied statistical case study; methodologically argues
  for disaggregation by substantively relevant third variables.
  },
  keywords  = {simpsons-paradox, discrimination, sex-bias, aggregation, institutional-bias, High},
  abstract = {Examination of aggregate data on graduate admissions to the University of California, Berkeley, for fall 1973 shows a clear but misleading pattern of bias against female applicants. Examination of the disaggregated data reveals few decision-making units that show statistically significant departures from expected frequencies of female admissions, and about as many units appear to favor women as to favor men. If the data are properly pooled, taking into account the autonomy of departmental decision making, thus correcting for the tendency of women to apply to graduate departments that are more difficult for applicants of either sex to enter, there is a small but statistically significant bias in favor of women. The graduate departments that are easier to enter tend to be those that require more mathematics in the undergraduate preparatory curriculum. The bias in the aggregated data stems not from any pattern of discrimination on the part of admissions committees, which seem quite fair on the whole, but apparently from prior screening at earlier levels of the educational system. Women are shunted by their socialization and education toward fields of graduate study that are generally more crowded, less productive of completed degrees, and less well funded, and that frequently offer poorer professional employment prospects.},
  abstract_source = {openalex},
}

@article{hernan2011simpsons,
  author    = {Hern\'{a}n, Miguel A and Clayton, David and Keiding, Niels},
  title     = {The {Simpson's} paradox unraveled},
  journal   = {International Journal of Epidemiology},
  year      = {2011},
  volume    = {40},
  number    = {3},
  pages     = {780--785},
  doi       = {10.1093/ije/dyr041},
  note      = {
  CORE ARGUMENT: Hernan, Clayton, and Keiding re-examine the original
  Simpson (1951) example and show that the "paradox" dissolves once the
  causal structure of the data-generating process is made explicit. They
  distinguish two distinct epidemiological phenomena -- confounding and
  non-collapsibility -- that are often conflated as "Simpson's paradox"
  and argue that analytical errors arise from stripping data of their
  causal context and analysing them purely statistically.

  RELEVANCE: Provides a working template for the research project's
  analysis: once the causal structure (poverty as common cause) is
  made explicit, the aggregate association disappears, confirming that
  the official's inference is an artifact of omitted-variable bias,
  not a genuine causal relationship.

  POSITION: Causal epidemiology; reinforces Pearl's framework with
  an empirical demonstration.
  },
  keywords  = {simpsons-paradox, confounding, epidemiology, causal-inference, omitted-variable, Medium},
  abstract = {Background In a famous article, Simpson described a hypothetical data example that led to apparently paradoxical results. Methods We make the causal structure of Simpson's example explicit. Results We show how the paradox disappears when the statistical analysis is appropriately guided by subject-matter knowledge. We also review previous explanations of Simpson's paradox that attributed it to two distinct phenomena: confounding and non-collapsibility. Conclusion Analytical errors may occur when the problem is stripped of its causal context and analyzed merely in statistical terms.},
  abstract_source = {openalex},
}

@book{eells1991probabilistic,
  author    = {Eells, Ellery},
  title     = {Probabilistic Causality},
  publisher = {Cambridge University Press},
  year      = {1991},
  doi       = {10.1017/cbo9780511570667},
  note      = {
  CORE ARGUMENT: Eells develops a sophisticated probabilistic theory
  of causation in which causal claims are evaluated relative to
  "causally homogeneous" population partitions. He argues that the
  appropriate partition for evaluating whether C causes E consists of
  all factors that are causally relevant to E independently of C.
  Simpson's paradox arises when this partition is ignored, and the
  correct partition is determined by causal, not probabilistic,
  criteria.

  RELEVANCE: Provides the probabilistic causation framework for
  understanding why the profiling official's aggregate hit rate fails
  as a causal indicator: the relevant partition (by income) is
  causally homogeneous, and within it the group-level effect vanishes.

  POSITION: Probabilistic theory of causation; the most detailed
  philosophical account of how to handle Simpson's paradox within
  a Suppes-style framework.
  },
  keywords  = {probabilistic-causation, simpsons-paradox, homogeneous-partitions, philosophy-of-causation, Medium},
  abstract = {In this important book, Ellery Eells explores and refines philosophical conceptions of probabilistic causality. In a probabilistic theory of causation, causes increase the probability of their effects rather than necessitate their effects in the ways traditional deterministic theories have specified. Philosophical interest in this subject arises from attempts to understand population sciences as well as indeterminism in physics. Taking into account issues involving spurious correlation, probabilistic causal interaction, disjunctive causal factors, and temporal ideas, Professor Eells advances the analysis of what it is for one factor to be a positive causal factor for another. A salient feature of the book is a theory of token level probabilistic causation in which the evolution of the probability of a later event from an earlier event is central. This will be a book of crucial significance to philosophers of science and metaphysicians; it will also prove stimulating to many economists, psychologists, and physicists.},
  abstract_source = {openalex},
}

@book{spirtes2000causation,
  author    = {Spirtes, Peter and Glymour, Clark and Scheines, Richard},
  title     = {Causation, Prediction, and Search},
  publisher = {MIT Press},
  year      = {2000},
  edition   = {2nd},
  note      = {
  CORE ARGUMENT: Spirtes, Glymour, and Scheines develop the causal
  Bayes net framework, establishing conditions (Causal Markov Condition,
  Faithfulness Assumption) under which causal structure can be inferred
  from observational data via constraint-based algorithms (PC, FCI).
  They show that confounders generate specific patterns of conditional
  independence violations detectable in data, and that Simpson's
  paradox instances correspond to structures where a confounding
  variable creates both differential base rates and differential
  outcome rates.

  RELEVANCE: Provides the algorithmic complement to Pearl's do-calculus:
  a framework for detecting when an omitted variable is generating the
  observed aggregate association, and for inferring the corrected
  conditional effect. This is the framework underlying formal analyses
  of when group-level statistics are biased by omitted confounders.

  POSITION: Causal discovery / graphical causal models; complementary
  to Pearl but emphasising identification from data.
  },
  keywords = {causal-inference, DAG, confounding, causal-discovery, graphical-models, High, INCOMPLETE, no-abstract}
}

@article{dong2024simpsons,
  author    = {Dong, Zili and Cai, Weixin and Zhao, Shimin},
  title     = {{Simpson's} paradox beyond confounding},
  journal   = {European Journal for Philosophy of Science},
  year      = {2024},
  volume    = {14},
  number    = {3},
  doi       = {10.1007/s13194-024-00610-8},
  note      = {
  CORE ARGUMENT: Dong, Cai, and Zhao argue that Pearl's causal-
  graphical analysis does not fully resolve Simpson's paradox because
  the reversal can arise from causal graph structures other than
  confounding -- including mediation, selection, and mutual causation.
  Each structural type calls for a different analytical response, and
  treating all reversals as confounding-to-be-adjusted for is an
  oversimplification that can itself introduce errors.

  RELEVANCE: Directly relevant to the research project's causal
  model: if the feedback loop generates a second-stage selection
  effect (increased policing of the group increases the observed
  rate of detected offences), the Simpson's reversal may involve
  a collider or mediator, not just a confounder. Distinguishing
  these structures is essential for policy analysis.

  POSITION: Extension and critique of Pearl's causal-graphical
  account; argues for a taxonomy of causal structures underlying
  the paradox.
  },
  keywords  = {simpsons-paradox, causal-graph, confounding, collider, mediation, philosophy-of-science, Medium},
  abstract = {Simpson’s paradox (SP) is a statistical phenomenon where the association between two variables reverses, disappears, or emerges, after conditioning on a third variable. It has been proposed (by, e.g., Judea Pearl) that SP should be analyzed using the framework of graphical causal models (i.e., causal DAGs) in which SP is diagnosed as a symptom of confounding bias. This paper contends that this confounding-based analysis cannot fully capture SP: there are cases of SP that cannot be explained away in terms of confounding. Previous works have argued that some cases of SP do not require causal analysis at all. Despite being a logically valid counterexample, we argue that this type of cases poses only a limited challenge to Pearl’s analysis of SP. In our view, a more powerful challenge to Pearl comes from cases of SP that do require causal analysis but can arise without confounding. We demonstrate with examples that accidental associations due to genetic drift, the use of inappropriate aggregate variables as causes, and interactions between units (i.e., inter-unit causation) can all give rise to SP of this type. The discussion is also extended to the amalgamation paradox (of which SP is a special form) which can occur due to the use of non-collapsible association measures, in the absence of confounding.},
  abstract_source = {s2},
}

@article{kievit2013simpsons,
  author    = {Kievit, Rogier A. and Frankenhuis, Willem E. and Waldorp, Lourens J. and Borsboom, Denny},
  title     = {{Simpson's} paradox in psychological science: a practical guide},
  journal   = {Frontiers in Psychology},
  year      = {2013},
  volume    = {4},
  doi       = {10.3389/fpsyg.2013.00513},
  note      = {
  CORE ARGUMENT: The authors argue that Simpson's paradox is more
  common in psychological data than conventionally assumed, and that
  it arises systematically when population-level inferences are drawn
  to sub-group or individual levels without explicit multi-level
  modelling. They provide empirical examples from several sub-fields,
  identify statistical markers that signal the paradox's presence, and
  propose an R toolbox for detection.

  RELEVANCE: The practical dimension -- that the paradox is ubiquitous
  in real institutional data and typically goes undetected -- supports
  the research project's claim that profiling feedback loops are not
  exotic but structurally predictable. The proposal for explicit level
  modelling corresponds to the corrective measure (conditioning on
  income) that the official fails to apply.

  POSITION: Applied statistical methodology; normative argument for
  multi-level statistical practices.
  },
  keywords  = {simpsons-paradox, multi-level-modelling, psychological-science, applied-statistics, Low},
  abstract = {The direction of an association at the population-level may be reversed within the subgroups comprising that population—a striking observation called Simpson’s paradox. When facing this pattern, psychologists often view it as anomalous. Here, we argue that Simpson’s paradox is more common than conventionally thought, and typically results in incorrect interpretations – potentially with harmful consequences. We support this claim by drawing on empirical results from cognitive neuroscience, behavior genetics, psychopathology, personality psychology, educational psychology, intelligence research, and simulation studies. We show that Simpson’s Paradox is most likely to occur when inferences are drawn across different levels of explanation (e.g., from populations to subgroups, or subgroups to individuals). We propose a set of statistical markers indicative of the paradox, and offer psychometric solutions for dealing with the paradox when encountered—including a toolbox in R for detecting Simpson’s Paradox. We show that explicit modeling of situations in which the paradox might occur not only prevents incorrect interpretations of data, but also results in a deeper understanding of what data tell us about the world.},
  abstract_source = {openalex},
}

@article{tverskykahnemanJudgmentUncertainty1974,
  author = {Tversky, Amos and Kahneman, Daniel},
  title = {Judgment under Uncertainty: Heuristics and Biases},
  journal = {Science},
  year = {1974},
  volume = {185},
  number = {4157},
  pages = {1124--1131},
  doi = {10.1126/science.185.4157.1124},
  note = {
  CORE ARGUMENT: Demonstrates that human probability judgments systematically deviate from Bayesian norms through three heuristics -- representativeness, availability, and anchoring-adjustment -- each producing characteristic biases. In problems involving base rates and conditional probabilities, subjects consistently neglect prior probabilities (base rate neglect), overweighting individuating information. The representativeness heuristic, which substitutes the question of how typical a case is for the question of its conditional probability, is particularly relevant: stereotyping involves treating a person as representative of a category and ignoring base-rate heterogeneity within that category.

  RELEVANCE: Provides the cognitive science foundation for understanding why Bayesian agents -- or agents approximating Bayesian reasoning -- systematically misweight prior probabilities when making individual judgments. In the profiling context, base rate neglect explains why officers form judgments of individual suspects based on group-level statistics rather than appropriately weighted conditional probabilities. The paper's demonstration that heuristic biases are systematic (not random) supports the claim that profiling-based updating is reliably distorting.

  POSITION: Foundational empirical challenge to the normative adequacy of naive Bayesian reasoning in practice; establishes that human judgment systematically violates conditionalization norms through identifiable mechanisms.
  },
  keywords = {base-rate-neglect, heuristics-biases, judgment-under-uncertainty, cognitive-science, High},
  abstract = {This article described three heuristics that are employed in making judgments under uncertainty: (i) representativeness, which is usually employed when people are asked to judge the probability that an object or event A belongs to class or process B; (ii) availability of instances or scenarios, which is often employed when people are asked to assess the frequency of a class or the plausibility of a particular development; and (iii) adjustment from an anchor, which is usually employed in numerical prediction when a relevant value is available. These heuristics are highly economical and usually effective, but they lead to systematic and predictable errors. A better understanding of these heuristics and of the biases to which they lead could improve judgments and decisions in situations of uncertainty.},
  abstract_source = {openalex},
}

@article{skyrms1987dynamic,
  author = {Skyrms, Brian},
  title = {Dynamic Coherence and Probability Kinematics},
  journal = {Philosophy of Science},
  year = {1987},
  volume = {54},
  number = {1},
  pages = {1--20},
  doi = {10.1086/289350},
  note = {
  CORE ARGUMENT: Argues that the conditionalization rule is normatively grounded in "dynamic coherence" -- an agent who plans to violate conditionalization is diachronically Dutch-bookable, meaning a sequence of bets can be constructed against them that guarantees a sure loss. This extends the standard synchronic Dutch book argument for the probability axioms to the temporal case of belief revision. Skyrms also extends this argument to Jeffrey conditionalization, showing that probability kinematics is similarly justified when evidence is uncertain.

  RELEVANCE: Establishes the canonical defense of conditionalization as a normative requirement. For the profiling feedback loop project, this is the baseline against which pathological cases are measured: the question becomes whether this dynamic coherence defense holds when the evidence stream itself is not exogenous but shaped by the agent's prior actions. If an agent's prior beliefs cause them to generate biased evidence, dynamic coherence does not guarantee truth-tracking.

  POSITION: Foundational defense of conditionalization through Dutch book arguments; assumes evidence is exogenous to prior beliefs.
  },
  keywords = {conditionalization, Dutch-book, dynamic-coherence, probability-kinematics, High},
  abstract = {The question of coherence of rules for changing degrees of belief in the light of new evidence is studied, with special attention being given to cases in which evidence is uncertain. Belief change by the rule of conditionalization on an appropriate proposition and belief change by “probability kinematics“ on an appropriate partition are shown to have like status.},
  abstract_source = {openalex},
}

@article{greavesWallaceJustifying2006,
  author = {Greaves, Hilary and Wallace, David},
  title = {Justifying Conditionalization: Conditionalization Maximizes Expected Epistemic Utility},
  journal = {Mind},
  year = {2006},
  volume = {115},
  number = {459},
  pages = {607--632},
  doi = {10.1093/mind/fzl607},
  note = {
  CORE ARGUMENT: Offers a non-pragmatic, accuracy-based justification for conditionalization: among all possible updating procedures, conditionalizing on evidence maximizes expected epistemic utility (measured by accuracy scores such as the Brier score). This decision-theoretic argument does not rely on Dutch books but instead grounds conditionalization in the goal of having accurate beliefs. The result holds in the finite-worlds setting where agents know what partition their evidence will come from.

  RELEVANCE: Provides the most sophisticated contemporary defense of conditionalization as epistemically rational. For the profiling project, this justification faces a structural limitation: it assumes the agent does not know ex ante that their evidence will be biased. When evidence is endogenously generated by prior beliefs (as in profiling), the expected-accuracy argument may fail because the agent's updating procedure is itself distorting the evidence stream. This paper is the foil against which Vassend (2026) and Gallow (2019) develop their critiques.

  POSITION: Accuracy-first defense of conditionalization; sets the stage for identifying conditions under which this defense breaks down.
  },
  keywords = {conditionalization, epistemic-utility, accuracy, Dutch-book-free, High},
  abstract = {According to Bayesian epistemology, the epistemically rational agent updates her beliefs by conditionalization: that is, her posterior subjective probability after taking account of evidence X, p new , is to be set equal to her prior conditional probability p old ($|X). Bayesians can be challenged to provide a justification for their claim that conditionalization is recommended by rationality-whence the normative force of the injunction to conditionalize?},
  abstract_source = {openalex},
}

@article{arntzenius2003problems,
  author = {Arntzenius, Frank},
  title = {Some Problems for Conditionalization and Reflection},
  journal = {Journal of Philosophy},
  year = {2003},
  volume = {100},
  number = {7},
  pages = {356--370},
  doi = {10.5840/jphil2003100729},
  note = {
  CORE ARGUMENT: Identifies several scenarios in which standard conditionalization either gives the wrong result or fails to apply: cases involving memory loss, centered worlds (self-locating belief), and situations where an agent receives evidence they could not have anticipated as a probability-zero event. Argues that reflection (the van Fraassen principle that an agent's current credences should equal their expectation of their future credences) also faces pathological counterexamples, including cases of expected memory loss. These failures suggest that standard Bayesian updating is norm-sensitive to idealized assumptions about the agent's epistemic situation.

  RELEVANCE: Directly relevant to cases where the evidence received by a profiling agent is not simply a partition element from a pre-specified possibility space, but an outcome whose very occurrence is shaped by prior beliefs and actions. The "unexpected evidence" and "memory loss" cases structurally parallel situations where an agent's prior actions determine what evidence they will encounter.

  POSITION: Internal critique of conditionalization from within the Bayesian tradition; identifies specific structural conditions where the norms fail.
  },
  keywords = {conditionalization-limits, reflection-principle, pathological-Bayesianism, self-location, High, INCOMPLETE, no-abstract}
}

@article{rabinSchrag1999confirmatory,
  author = {Rabin, M. and Schrag, J. L.},
  title = {First Impressions Matter: A Model of Confirmatory Bias},
  journal = {The Quarterly Journal of Economics},
  year = {1999},
  volume = {114},
  number = {1},
  pages = {37--82},
  doi = {10.1162/003355399555945},
  note = {
  CORE ARGUMENT: Develops a formal economic model in which agents with confirmatory bias systematically misread signals that contradict their current hypothesis: with probability q, a disconfirming signal is misread as confirming. Even small values of q cause agents to become locked into a false first impression with positive probability, converging on the wrong hypothesis as evidence accumulates. The model predicts that confirmatory bias leads to greater entrenchment of false beliefs over time, not convergence to truth, because each new piece of evidence is filtered through the lens of prior belief.

  RELEVANCE: Provides the closest formal precedent for the profiling feedback loop model in the research project. The mechanism -- misreading of disconfirming signals -- parallels how profiling agents may dismiss or reinterpret exculpatory evidence as non-representative. The Rabin-Schrag model demonstrates formally that epistemically biased processing of evidence can lead to permanent error even with unlimited data, which is precisely the claim the profiling project seeks to establish in a more specific institutional context.

  POSITION: Formal model of confirmatory bias showing that endogenous evidence filtering causes belief entrenchment; foundational for the economic literature on non-Bayesian updating.
  },
  keywords = {confirmatory-bias, belief-entrenchment, non-Bayesian-updating, formal-model, High},
  abstract = {Psychological research indicates that people have a cognitive bias that leads them to misinterpret new information as supporting previously held hypotheses. We show in a simple model that such &lt;it&gt;confirmatory bias&lt;/it&gt; induces overconfidence: given any probabilistic assessment by an agent that one of two hypotheses is true, the appropriate beliefs would deem it less likely to be true. Indeed, the hypothesis that the agent believes in may be more likely to be &lt;it&gt;wrong&lt;/it&gt; than right. We also show that the agent may come to believe with near certainty in a false hypothesis despite receiving an infinite amount of information.},
  abstract_source = {openalex},
}

@article{nimarkSundaresan2019inattention,
  author = {Nimark, Kristoffer P. and Sundaresan, Savitar},
  title = {Inattention and Belief Polarization},
  journal = {Journal of Economic Theory},
  year = {2019},
  volume = {180},
  pages = {203--228},
  doi = {10.1016/j.jet.2018.12.007},
  note = {
  CORE ARGUMENT: Models belief polarization among fully rational Bayesian agents who choose what signals to attend to. When information costs are proportional to channel capacity, rational agents prefer signal structures that are more likely to confirm their prior beliefs (the "confirmation effect") and reduce their signal precision as their prior becomes more confident (the "complacency effect"). Together these effects cause ex ante identical rational agents to diverge into two polarized groups with opposing beliefs, even as evidence accumulates. Polarization is self-reinforcing because selective inattention to disconfirming signals is individually rational.

  RELEVANCE: Provides a fully rational model of selective evidence gathering that generates self-reinforcing false belief -- exactly the mechanism at work in profiling feedback loops. A police officer who rationally attends more to confirming cases (high-crime areas in the profiled community) and discounts information from other contexts is behaving as a Nimark-Sundaresan agent. The paper shows that the problem is not irrationality but rather the rational response to information costs, making it particularly important for the philosophical argument that profiling is epistemically self-undermining even when individual decisions appear locally rational.

  POSITION: Rational choice model showing that endogenous evidence selection causes permanent belief polarization among Bayesian agents; bridges economics and epistemology.
  },
  keywords = {belief-polarization, rational-inattention, endogenous-evidence, self-confirming, High},
  abstract = {Disagreement persists over issues that have objective truths. In the presence of increasing amounts of data, such disagreement should vanish, but it is nonetheless observable. This paper studies persistent disagreement in a model where Bayesian rational agents learn about an unobserved state through noisy signals. We show that agents (i) choose signal structures that are more likely to reinforce their prior beliefs and (ii) choose signal precisions that are inversely related to the precision of their prior beliefs. We call the former the confirmation effect and the latter the complacency effect. The complacency effect may lead agents to stop updating their beliefs entirely, leading to permanent disagreement among agents about the true state of nature. Taken together, the confirmation and complacency effect imply that the beliefs of ex ante identical agents over time tend to cluster in two distinct groups near the boundaries of the belief space. The complacency effect is stronger and more general when information cost is proportional to channel capacity, compared to when it is proportional to reduction in entropy. We argue that in some settings, it may be more natural to model the cost of attention as proportional to channel capacity, rather than the common practice of specifying information cost as proportional to entropy reduction.},
  abstract_source = {s2},
}

@article{bacchusKyburgThalos1990,
  author = {Bacchus, F. and Kyburg, H. E. and Thalos, M.},
  title = {Against conditionalization},
  journal = {Synthese},
  year = {1990},
  volume = {85},
  number = {3},
  pages = {475--506},
  doi = {10.1007/bf00484837},
  note = {
  CORE ARGUMENT: Argues that conditionalization is not the uniquely correct updating rule, and that there are epistemically legitimate cases where an agent should not simply conditionalize on their evidence. The paper distinguishes between evidence that is purely propositional and evidence that carries additional information about its own provenance or the sampling process that generated it. When evidence carries this additional structure, conditioning on the raw proposition can systematically mislead. The authors propose that agents should sometimes revise their entire prior framework rather than update within it.

  RELEVANCE: Directly supports the key claim that conditionalization is epistemically deficient when evidence is generated by a biased process. If a profiling agent's evidence comes from a non-representative sample of the population (only scrutinized individuals), conditioning on that evidence without adjusting for the sampling process will entrench false beliefs. Bacchus et al. provide a principled philosophical basis for the view that formal validity of conditionalization is compatible with epistemic deficiency.

  POSITION: Anti-conditionalization argument from within formal epistemology; challenges the universality of the conditionalization norm.
  },
  keywords = {against-conditionalization, sampling-bias, evidence-provenance, formal-epistemology, High},
  abstract = {The central focus of this paper is conditionalization, but we also address related principles such as that of reflection. It is argued that dutch book theorems do not show what they are intended to show in the ordinary (static) case, and that they are even less persuasive in the dynamic case to which conuitionalization applies. The first point is that to be forced to post odds and meet the bets of all comers reveals something about one&apos;s rationality, bu t nothing about one&apos;s degrees of belief. Adding conditional bets to the requirements of posting adds nothing to the rational constraints. We consider the argument of Paul Teller, which does address the genuinely dynamic consideration of changes of belief in the face of evidence. We argue that Teller&apos;s principle P is not a principle of rationality. This claim is relevant to the controversy concerning scientific change and its relation to anomalies in scientific theory. The principle of reflection introduced by van Fraassen fares no better. Finally, it is shown that suggestions of Carnap himself lead to the violation of conditionalization. Carnap may not have been infallible, but his intuitions concerning inductive relations were surely good enough to take into account. Overall, we find no compelling argument in favor of conditionalization as a genera.l principle, however important it may be in special circumstances},
  abstract_source = {core},
}

@article{magnusCallender2004realist,
  author = {Magnus, P. D. and Callender, Craig},
  title = {Realist Ennui and the Base Rate Fallacy},
  journal = {Philosophy of Science},
  year = {2004},
  volume = {71},
  number = {3},
  pages = {320--338},
  doi = {10.1086/421536},
  note = {
  CORE ARGUMENT: Argues that the traditional no-miracles argument for scientific realism commits the base rate fallacy: the argument treats the predictive success of theories as evidence for their truth without specifying the prior probability of theories being true. If the base rate of true theories is low, even high predictive success provides weak confirmation. The paper uses this as a case study to illuminate a general epistemological point: Bayesian inference requires explicit attention to prior probabilities (base rates), and neglecting them leads to systematically inflated posterior credences.

  RELEVANCE: Illustrates the base rate fallacy in a purely philosophical context, providing a clear model of how ignoring base rates leads to epistemically distorted conclusions. In the profiling context, the base rate of criminal activity in a scrutinized population is not determined by their group membership, and ignoring the actual base rate while treating group membership as a proxy leads to the same fallacy Magnus and Callender diagnose in the realism debate. This paper provides a useful philosophical bridge between the cognitive science literature on base rate neglect and the formal Bayesian epistemology of confirmation.

  POSITION: Philosophy of science application of base rate reasoning, demonstrating that neglect of prior probabilities is a systematic epistemological failure with practical consequences.
  },
  keywords = {base-rate-fallacy, Bayesian-confirmation, prior-probability, philosophy-of-science, High},
  abstract = {The no-miracles argument and the pessimistic induction are arguably the main considerations for and against scientific realism. Recently these arguments have been accused of embodying a familiar, seductive fallacy. In each case, we are tricked by a base rate fallacy, one much-discussed in the psychological literature. In this paper we consider this accusation and use it as an explanation for why the two most prominent ‘wholesale’ arguments in the literature seem irresolvable. Framed probabilistically, we can see very clearly why realists and anti-realists have been talking past one another. We then formulate a dilemma for advocates of either argument, answer potential objections to our criticism, discuss what remains (if anything) of these two major arguments, and then speculate about a future philosophy of science freed from these two arguments. In so doing, we connect the point about base rates to the wholesale/retail distinction; we believe it hints at an answer of how to distinguish profitable from unprofitable realism debates. In short, we offer a probabilistic analysis of the feeling of ennui afflicting contemporary philosophy of science.},
  abstract_source = {openalex},
}

@article{vassend2026ecological,
  author = {Vassend, Olav Benjamin},
  title = {On the Ecological and Internal Rationality of Bayesian Conditionalization and Other Belief Updating Strategies},
  journal = {The British Journal for the Philosophy of Science},
  year = {2026},
  doi = {10.1086/724447},
  note = {
  CORE ARGUMENT: Demonstrates that Bayesian conditionalization is ecologically suboptimal in common real-world scenarios even for computationally unbounded ideal agents. An updating strategy is "ecologically rational" if it converges to accurate beliefs given the environment in which it is applied; Vassend shows that conditionalization can fail this standard when the agent's model of the world is misspecified or when evidence arrives from non-representative samples. The paper proposes a broader notion of epistemic rationality than expected utility maximization alone, identifying narrow conditions under which conditionalization is guaranteed to be ecologically optimal.

  RELEVANCE: Provides the most recent philosophical analysis of conditionalization's ecological limits, directly relevant to the profiling project's claim that updating on biased evidence is epistemically deficient even when formally valid. Vassend's framework distinguishes "internal" rationality (coherence with one's own probability function) from "ecological" rationality (convergence to truth given the actual environment), a distinction that precisely maps onto the profiling problem: profiling agents may be internally rational while being ecologically irrational when the evidence stream is systematically biased.

  POSITION: Ecologically-minded critique of conditionalization as a universal norm; distinguishes coherence from accuracy-in-environment.
  },
  keywords = {ecological-rationality, conditionalization-limits, epistemic-environment, accuracy, High},
  abstract = {According to Bayesians, agents should respond to evidence by conditionalizing their prior degrees of belief on what they learn. The main aim of this paper is to demonstrate that there are common scenarios in which Bayesian conditionalization is less rational—both from an ecological and an internal perspective—than other theoretically well-motivated belief updating strategies, even in very simple situations and even for an “ideal” agent who is computationally unbounded. The examples also serve to demarcate the narrow conditions under which Bayesian conditionalization is guaranteed to be ecologically optimal. A second aim of the paper is to argue for a broader notion of rationality than what is typically assumed in formal epistemology. On this broader understanding of rationality, classical decision theoretic principles such as expected utility maximization play a less important role.},
  abstract_source = {s2},
}

@article{gallow2019updating,
  author = {Gallow, J. Dmitri},
  title = {Updating for externalists},
  journal = {Nous},
  year = {2019},
  volume = {55},
  number = {3},
  pages = {487--516},
  doi = {10.1111/nous.12307},
  note = {
  CORE ARGUMENT: Argues that if externalism about evidence is correct -- if an agent's evidence can fail to tell them what evidence they have -- then standard conditionalization becomes self-defeating. An externalist Bayesian who conditionalizes can engage in "deliberate self-delusion": repeatedly "learning" from experience in ways that drive credence in false propositions arbitrarily high. Gallow proposes an alternative updating rule justified by expected accuracy maximization that does not require internalist assumptions about self-knowledge of evidence.

  RELEVANCE: Establishes that conditionalization fails as a normative guide when agents cannot be certain about the epistemic quality of their own evidence -- a condition that obtains precisely in profiling contexts, where the evidence stream is endogenous to prior beliefs. A profiling agent who internalizes their biased sampling process as "normal" evidence, without awareness that it is a non-representative sample, faces the self-delusion problem Gallow identifies. The paper thus provides a formal epistemological basis for the claim that profiling feedback loops constitute genuine epistemic pathology, not merely biased but internally coherent reasoning.

  POSITION: Externalist critique of conditionalization; shows that biased evidence recognition leads to epistemically self-undermining updating patterns.
  },
  keywords = {externalism, conditionalization-failure, self-delusion, evidence-access, Medium},
  abstract = {The externalist says that your evidence could fail to tell you what evidence you do or not do have. In that case, it could be rational for you to be uncertain about what your evidence is. This is a kind of uncertainty which orthodox Bayesian epistemology has difficulty modeling. For, if externalism is correct, then the orthodox Bayesian learning norms of conditionalization and reflection are inconsistent with each other. I recommend that an externalist Bayesian reject conditionalization. In its stead, I provide a new theory of rational learning for the externalist. I defend this theory by arguing that its advice will be followed by anyone whose learning dispositions maximize expected accuracy. I then explore some of this theory’s consequences for the rationality of epistemic akrasia, peer disagreement, undercutting defeat, and uncertain evidence. O rthodox Bayesian epistemology is designed to model rational uncertainty. 1 When you lack relevant evidence, its norms permit uncertainty about various and sundry matters: the weather, the victor, the price of tea in China. But there is a certain kind of uncertainty which orthodox Bayesianism has more difficulty modeling: uncertainty about what evidence you do or do not possess. Influential arguments in support of orthodox Bayesianism take for granted that your evidence will always tell you what your total evidence is, so that there may be no uncertainty about what your evidence says. Let’s call this thesis ‘internalism’, Final draft; forthcoming in Noûs. † For helpful conversations and feedback on this material, I am indebted to Sara Aronowitz, Adam Bjorndahl, Catrin Campbell-Moore, Nilanjan Das, Kevin Dorst, Daniel Drucker, Julien Dutant, Adam Elga, Jeremy Goodman, Harvey Lederman, Stephen Mackereth, Alexander Meehan, Jim Joyce, Jim Pryor, Daniel Rothschild, Teddy Seidenfeld, Julia Staffel, Robert Steel, Pablo Zendejas Medina, Snow Zhang, and two anonymous reviewers. Thanks also to audiences at Princeton University, University College London, the Updating and Experience conference at Ruhr University, Bochum, the Formal Epistemology Seminar at Carnegie Mellon University, and the 2019 Pitt-CMU Graduate conference. 1 As I’ll understand the position, orthodox Bayesianism is committed to at least the following theses: probabilism, which says that rational credences are (at least finitely additive) probabilities; conditionalization, which says that you should be disposed to learn from your evidence by conditioning on it (see §2), and van Fraassen’s principle of reflection, which says that your current credences should equal your expectation of your future credences (see §2.1). For each of these assumptions, there are epistemologists justly called ‘Bayesian’ who deny it; but these assumptions compose a familiar, ‘off-the-shelf ’ Bayesian theory of rationality. updating for externalists 2 of 30 and let’s call its negation ‘externalism’.2 The externalist thinks that your evidence could fail to tell you what evidence you have or don’t have, in which case, it could be rational for you to be uncertain about what your evidence is. Both internalism and externalism have able defenders. Myself, I’m undecided. I can feel the force of arguments on both sides. So I won’t be defending either position here. Instead, I will be asking: what becomes of orthodox Bayesianism if externalism is correct? And on this question, I am decided. The externalist Bayesian should reject the orthodox learning norm (or updating rule) of conditionalization. This is a lesson I’ve learned from Salow (2018), who teaches that, if an externalist Bayesian follows conditionalization, then they will be capable of engaging in acts of deliberate self-delusion—repeatedly ‘learning’ from experience in such a way as to raise their rational credence in some proposition as high as they like, even when the proposition is false. It is difficult to see this as rational inquiry. So I recommend that the externalist reject conditionalization. In its stead, I will advance a new theory of rational learning for the externalist. I’ll defend this theory by arguing that its advice will be followed by anyone whose learning dispositions maximize expected accuracy. And I’ll show that those who follow this theory’s advice will be incapable of engaging in deliberate self-delusion. Assuming evidentialism—that is, assuming that the rationality of your doxastic states is determined by the evidence you possess—externalism entails that your evidence could fail to tell you whether your doxastic states are rational or not. For this reason, externalism has played a starring role in recent debates about the rationality of epistemic akrasia. Some externalists have held that your evidence could make it likely both that it will rain and that your evidence doesn’t make it likely that it will rain. In that case, they have proposed that it is rational for you to be epistemically akratic, believing both that it will rain and that it’s irrational to believe that it will rain. Relatedly, some externalists have held that the disagreement of an epistemic peer—who has all the evidence that you do, and is equally good at evaluating it as you are—may give you reason to think that your belief in rain was irrationally formed; nevertheless, this need not give you any reason to revise your views about the weather.3 The externalist theory of learning I’ll develop here yields a distinctive form of externalism, according to which certain kinds of epistemic akrasia are always irra2 Internalism is presupposed by the Lewis-Teller diachronic Dutch book argument for conditionalization (for more, see Gallow 2017), as well as the more recent accuracy (or ‘epistemic utility’) arguments for conditionalization from Greaves & Wallace and Briggs & Pettigrew (forthcoming) (for more, see Schoenfield 2017a). For justifications of conditionalization which do not presuppose internalism, see (for instance) van Fraassen (1989, ch. 13), Lange (1999), Leitgeb & Pettigrew (2010b), Titelbaum (2013, ch. 7), Gallow (2019), and Zendejas Medina (ms). 3 For more, see Elga (2013), Weatherson (ms, 2013), Horowitz (2014), Greco (2014), Lasonen-Aarnio (2014, 2015, forthcoming), and §3. §1. internalism and externalism 3 of 30 tional; and, if the disagreement of an epistemic peer gives you reason to think that your beliefs were irrationally formed, then it can be rational for you to ‘conciliate’ with that peer after learning of the disagreement. It additionally gives guidance in cases of undercutting defeat, and learning experiences in which certainty in no proposition has been rationalized. The latter cases are usually treated with Jeffrey conditionalization (see Jeffrey, 1965). My past self treated the former with a norm I called holistic conditionalization (Gallow, 2014). I will show that, in the paradigm cases, the theory defended here agrees with both of these learning norms. 1 Internalism and Externalism In general, to be an internalist is to think that some condition must always lie within your epistemic reach. Given some condition c , an internalist says: if you satisfy c , then you must have access to the fact that you satisfy c . An externalist, in contrast, says that you may satisfy c without having access to the fact that you satisfy c . Different conditions and different kinds of access yield different forms of internalism and externalism. For instance: let the condition be being in pain, and say that you have access to a fact when you know it. We then get the internalist thesis that, if you are in pain, you must know that you are in pain, and the corresponding externalist thesis that you may be in pain without knowing that you are in pain. To get the form of internalism that I’ll be interested in, let the condition be possessing the total evidence e , and say that you have access to a fact when it is part of your evidence. Then, the internalist says: whenever e is your total evidence, your evidence must say that e is your total evidence. The externalist: on the contrary, sometimes e can be your total evidence without your evidence telling you that e is your total evidence.4 Internalism If e is your total evidence, then your evidence must tell you that e is your total evidence.  (Te → ETe ) Externalism You may have the total evidence e without your evidence telling you that e is your total evidence.},
  abstract_source = {s2},
}

@article{raidl2020openminded,
  author = {Raidl, Eric},
  title = {Open-Minded Orthodox Bayesianism by Epsilon-Conditionalization},
  journal = {The British Journal for the Philosophy of Science},
  year = {2020},
  volume = {71},
  number = {1},
  pages = {139--176},
  doi = {10.1093/bjps/axy075},
  note = {
  CORE ARGUMENT: Addresses the "zero-raising problem" of orthodox Bayesianism: once an agent assigns zero probability to a possibility, conditionalization can never raise it, trapping the agent in permanent certainty even when evidence suggests the neglected possibility is actual. Proposes "epsilon-conditionalization" as a modification: before conditionalizing, the agent mixes their prior with a small weight on previously neglected possibilities, enabling open-minded revision. This is the minimal modification to orthodox Bayesianism that accommodates fallibilism without abandoning the core commitment to probability theory.

  RELEVANCE: Directly relevant to the profiling feedback loop project as a formal model of how priors can become permanently entrenched. If a profiling agent assigns zero (or near-zero) prior probability to the hypothesis that their target group is non-criminal, no amount of non-confirming evidence can revise this belief. Epsilon-conditionalization points toward remediation: only a deliberate injection of epistemic humility (the epsilon mixing) can break the feedback loop. This paper helps explain both the mechanism of belief entrenchment and the formal conditions under which such entrenchment could in principle be corrected.

  POSITION: Constructive modification of Bayesianism to address zero-probability entrenchment; bridges orthodox Bayesianism and open-mindedness.
  },
  keywords = {zero-raising-problem, epsilon-conditionalization, belief-entrenchment, open-mindedness, Medium},
  abstract = {Orthodox Bayesianism endorses revising by conditionalization. This paper investigates the zero-raising problem, or equivalently the certainty-dropping problem of orthodox Bayesianism: previously neglected possibilities remain neglected, although the new evidence might suggest otherwise. Yet, one may want to model open-minded agents, that is, agents capable of raising previously neglected possibilities. Different reasons can be given for open-mindedness, one of which is fallibilism. The paper proposes a family of open-minded propositional revisions depending on a parameter ϵ. The basic idea is this: first extend the prior to the newly suggested possibilities by mixing the prior with the uniform probability on these possibilities, then conditionalize. This may put the agent back on the right track when her beliefs or evidence happen to be false. The paper justifies this family of equivocal epsilon-conditionalizations as minimal non-biased open-minded modifications of conditionalization. Several variations are discussed, such as mixing with an ad hoc or silent prior instead of the uniform prior, and a generalization to probabilistic information is given. The approach is compared to other accounts, such as Jeffrey’s Bayesianism, Gärdenfors’s probabilistic revision, maximizing entropy, and minimal revision. 1 Introduction 2 Downsides of Certainty Conservation 3 Why Raise Zeros?   3.1 Accuracy defects   3.2 Fallibilism and dissolutions   3.3 Weak fallibilism and partial solutions 4 Epsilon-Conditionalization   4.1 Definitions   4.2 Revision types and information assumptions   4.3 Epsilon interpretation and flavours 5 Justifications   5.1 Open-minded orthodox Bayesianism   5.2 Minimal revision   5.3 Transitivity 6 Conclusion Appendix 1 Introduction 2 Downsides of Certainty Conservation 3 Why Raise Zeros?   3.1 Accuracy defects   3.2 Fallibilism and dissolutions   3.3 Weak fallibilism and partial solutions   3.1 Accuracy defects   3.2 Fallibilism and dissolutions   3.3 Weak fallibilism and partial solutions 4 Epsilon-Conditionalization   4.1 Definitions   4.2 Revision types and information assumptions   4.3 Epsilon interpretation and flavours   4.1 Definitions   4.2 Revision types and information assumptions   4.3 Epsilon interpretation and flavours 5 Justifications   5.1 Open-minded orthodox Bayesianism   5.2 Minimal revision   5.3 Transitivity   5.1 Open-minded orthodox Bayesianism   5.2 Minimal revision   5.3 Transitivity 6 Conclusion Appendix},
  abstract_source = {s2},
}

@article{ortoleva2024alternatives,
  author = {Ortoleva, Pietro},
  title = {Alternatives to Bayesian Updating},
  journal = {Annual Review of Economics},
  year = {2024},
  volume = {16},
  number = {1},
  pages = {545--570},
  doi = {10.1146/annurev-economics-100223-050352},
  note = {
  CORE ARGUMENT: Systematic review of models of belief updating that depart from Bayesian conditionalization, organized around three sources of non-Bayesian behavior: (1) heuristics and biases (systematic cognitive errors), (2) questioning priors (agents revise their initial probability assignments in light of new evidence rather than conditionalizing), and (3) cognitive constraints (bounded rationality). The paper includes models of confirmatory bias, conservatism, overconfidence, and motivated beliefs, providing a taxonomy of ways that agents depart from the Bayesian ideal while still revising beliefs in response to evidence.

  RELEVANCE: Provides the most comprehensive recent survey of non-Bayesian updating models, directly useful for situating the profiling feedback loop within the broader literature on belief revision pathologies. The section on motivated beliefs and distance minimization is particularly relevant: agents may update toward belief states that are close to desirable conclusions rather than toward the Bayesian posterior, which parallels how profiling agents may select evidence that confirms prior suspicions.

  POSITION: Comprehensive taxonomy of non-Bayesian updating models from behavioral economics; provides formal frameworks for modeling belief entrenchment.
  },
  keywords = {non-Bayesian-updating, confirmatory-bias, motivated-beliefs, survey, Medium},
  abstract = {We discuss models of updating that depart from Bayes’ rule even when it is well-defined. After reviewing Bayes’ rule and its foundations, we begin our analysis with models of non-Bayesian behavior arising from a bias, a pull toward suboptimal behavior due to a heuristic or a mistake. Next, we explore deviations caused by individuals questioning the prior probabilities they initially used. We then consider non-Bayesian behavior resulting from the optimal response to constraints on perception, cognition, or memory, as well as models based on motivated beliefs or distance minimization. Finally, we briefly discuss models of updating after zero probability events.},
  abstract_source = {s2},
}

@article{vanDoorn2023skeptical,
  author = {van Doorn, Maarten},
  title = {The skeptical import of motivated reasoning: a closer look at the evidence},
  journal = {Thinking and Reasoning},
  year = {2023},
  volume = {30},
  number = {4},
  pages = {548--578},
  doi = {10.1080/13546783.2023.2276975},
  note = {
  CORE ARGUMENT: Critically examines the claim that belief-consistent information processing (confirmation bias, selective scrutiny, myside bias) necessarily constitutes motivated irrationality. Argues that many such phenomena -- including belief polarization and biased assimilation -- need not violate Bayesian norms, because the normative status of differential treatment of confirming versus disconfirming evidence depends on the agent's prior beliefs and the reliability of the evidence, not merely on whether the processing is belief-consistent. Distinguishes between irrationality grounded in the bare differential treatment of evidence and irrationality grounded in an underlying irrelevant influence (desire, partisan identity) that corrupts the weight-assignment process.

  RELEVANCE: Provides a philosophical analysis of the epistemic status of motivated reasoning relevant to the profiling project. The distinction between "belief-consistent processing" and "motivated irrationality" maps onto an important question: is a profiling agent who follows Bayesian norms on biased samples merely rationally processing their evidence, or are they epistemically deficient in a deeper sense? Van Doorn's analysis supports the view that the problem is not the bare formal validity of conditionalization but the underlying corrupting influence on evidence selection.

  POSITION: Nuanced analysis of the normative status of motivated reasoning; argues that formal Bayesian validity does not immunize against epistemic criticism.
  },
  keywords = {motivated-reasoning, confirmation-bias, epistemic-rationality, belief-consistent-processing, Medium},
  abstract = {Abstract Central to many discussions of motivated reasoning is the idea that it runs afoul of epistemic normativity. Reasoning differently about information supporting our prior beliefs versus information contradicting those beliefs, is frequently equated with motivated irrationality. By analyzing the normative status of belief polarization, selective scrutiny, biased assimilation and the myside bias, I show this inference is often not adequately supported. Contrary to what’s often assumed, these phenomena need not indicate motivated irrationality, even though they are instances of belief-consistent information processing. Second, I engage with arguments purporting to show that belief-consistent information processing does not indicate motivated irrationality because of its mere differential treatment of confirming and non-confirming evidence, but rather because it reveals the undermining presence of an irrelevant influence, such as a desire or partisan identity-driven cognition. While linking belief-consistent reasoning to a deeper source of directional motivation to make good on the claim that it indicates motivated irrationality is indeed what’s needed, two prominent such arguments fail. The non-normativity of many reasoning processes often taken to indicate motivated irrationality is not in fact well established.},
  abstract_source = {s2},
}

@article{lloyd2021epistemic,
  author = {Lloyd, Alexandra},
  title = {An Epistemic Objection to Racial Profiling},
  journal = {Social Epistemology},
  year = {2021},
  volume = {35},
  number = {6},
  pages = {636--644},
  doi = {10.1080/02691728.2021.1943560},
  note = {
  CORE ARGUMENT: Identifies an epistemic (not merely moral) objection to racial profiling: profiling relies on "naked statistical evidence" -- group-level base rates that are not causally connected to the individual case under consideration. Naked statistical evidence cannot justify outright belief in an individual's guilt or criminality; it can only justify high credence. Since the social practice of profiling often involves acting on outright belief (warranting blame, stop-and-search, etc.), the evidential basis is epistemically insufficient. The paper argues that statistical evidence fails to justify the epistemic posture that profiling requires, even before any moral objection is raised.

  RELEVANCE: Directly addresses the epistemological foundations of profiling as a practice, providing an epistemic objection that complements the moral critique. The claim that naked statistical evidence cannot support outright belief connects to the project's concern about how Bayesian credences are converted into discriminatory actions. Lloyd's analysis establishes that even formally valid probabilistic reasoning from prior group-level statistics cannot epistemically justify treating individuals as guilty, since the prior probabilities are causally disconnected from individual facts.

  POSITION: Applied epistemology of profiling; distinguishes high credence from justified belief and criticizes profiling's epistemic insufficiency.
  },
  keywords = {racial-profiling, naked-statistical-evidence, epistemic-objection, applied-epistemology, Medium},
  abstract = {ABSTRACT In this paper, I identify an important epistemic problem with the practice of racial profiling. Racial profiling relies on naked statistical evidence to justify reasonable suspicion. Naked statistical evidence refers to probabilities that are not created by a particular case, but that existed prior to or independently of the case under consideration (Wells, 1992). I argue that naked statistical evidence cannot justify outright belief in someone’s worthiness of suspicion, it can only justify a high credence. This is because statistical evidence fails to be causally connected to the particular case under consideration. According to our blame norms, a precondition for apt blame is that an agent has an outright belief that the agent is responsible for the act for which they are blamed; high credence cannot play this role. I argue that reasonable suspicion in the context of racial profiling frequently involves blame such that it demands the same strict evidential standards. Therefore, we can identify an important epistemic objection to this practice.},
  abstract_source = {s2},
}

@book{bovensHartmann2004bayesian,
  author = {Bovens, Luc and Hartmann, Stephan},
  title = {Bayesian Epistemology},
  year = {2004},
  publisher = {Oxford University Press},
  doi = {10.1093/0199269750.001.0001},
  note = {
  CORE ARGUMENT: Develops a systematic Bayesian epistemology that models the epistemology of testimony, coherence, reliability, and the aggregation of evidence from multiple sources. The book establishes that coherent belief systems can nonetheless systematically mislead agents when evidence sources are unreliable or correlated. A central result is that adding coherent but unreliable testimony can actually decrease overall probability rather than confirm it -- the "unreliable witnesses" problem shows that coherence of evidence does not guarantee accuracy.

  RELEVANCE: Provides a comprehensive formal framework for analyzing reliability and coherence in Bayesian reasoning, applicable to the profiling feedback loop in two ways. First, if the evidence an agent uses to update on group criminality comes from unreliable sources (biased police reports, correlated informants), the Bovens-Hartmann framework shows that such evidence can entrench false beliefs even when processed according to Bayesian norms. Second, the book establishes that formal coherence of a belief system is compatible with systematic epistemic failure, supporting the project's claim that profiling agents can be coherent yet wrong.

  POSITION: Standard reference for Bayesian modeling of evidence aggregation, reliability, and coherence; shows coherence compatible with systematic error.
  },
  keywords = {Bayesian-epistemology, coherence, reliability, evidence-aggregation, Medium},
  abstract = {Abstract Probabilistic models have much to offer to epistemology and philosophy of science. Arguably, the coherence theory of justification claims that the more coherent a set of propositions is, the more confident one ought to be in its content, ceteris paribus. An impossibility result shows that there cannot exist a coherence ordering. A coherence quasi-ordering can be constructed that respects this claim and is relevant to scientific-theory choice. Bayesian-Network models of the reliability of information sources are made applicable to Condorcet-style jury voting, Tversky and Kahneman’s Linda puzzle, the variety-of-evidence thesis, the Duhem–Quine thesis, and the informational value of testimony.},
  abstract_source = {openalex},
}

@book{titelbaum2022fundamentals1,
  author = {Titelbaum, Michael G.},
  title = {Fundamentals of Bayesian Epistemology 1},
  year = {2022},
  publisher = {Oxford University Press},
  doi = {10.1093/oso/9780198707608.001.0001},
  note = {
  CORE ARGUMENT: Provides a rigorous textbook treatment of Bayesian epistemology's foundations: the motivation for degrees of belief, Kolmogorov's axioms, the Ratio Formula for conditional credences, and conditionalization as the core updating norm. Critically, the book also catalogs challenges to the Bayesian framework: problems involving memory loss, self-location, old evidence, logical omniscience, and the subjectivity of priors. The treatment is notable for its systematic attention to the conditions under which conditionalization is normatively binding and the conditions under which those norms may fail or require modification.

  RELEVANCE: Serves as the standard pedagogical reference for Bayesian epistemology's foundations, establishing the normative framework against which the profiling feedback loop project positions itself. The book's catalog of challenges to conditionalization -- especially the problems arising from priors that are not responsive to evidence -- provides a taxonomy that the project can use to locate the profiling problem within the broader landscape of Bayesian pathologies.

  POSITION: Comprehensive contemporary reference for Bayesian epistemology's normative foundations and known challenges.
  },
  keywords = {Bayesian-epistemology, credences, conditionalization, textbook, Medium},
  abstract = {This book introduces readers to the fundamentals of Bayesian epistemology. It begins by motivating and explaining the idea of a degree of belief (also known as a “credence”). It then presents Bayesians’ five core normative rules governing degrees of belief: Kolmogorov’s three probability axioms, the Ratio Formula for conditional credences, and Conditionalization for updating credences over time. After considering a few proposed additions to these norms, it applies the core rules to confirmation and decision theory. The book then details arguments for the Bayesian rules based on representation theorems, Dutch Books, and accuracy measures. Finally, it looks at objections and challenges to Bayesian epistemology. It presents problems concerning memory loss, self-location, old evidence, logical omniscience, and the subjectivity of priors. It considers the rival statistical paradigms of frequentism and likelihoodism. Then it explores alternative Bayesian-style formalisms involving comparative confidence rankings, credences ranges, and Dempster-Shafer functions.},
  abstract_source = {s2},
}

@article{briggsPettigrew2018accuracy,
  author = {Briggs, R. A. and Pettigrew, Richard},
  title = {An Accuracy-Dominance Argument for Conditionalization},
  journal = {Nous},
  year = {2018},
  volume = {54},
  number = {1},
  pages = {162--181},
  doi = {10.1111/nous.12258},
  note = {
  CORE ARGUMENT: Provides a new accuracy-dominance argument for conditionalization: any updating plan other than conditionalization is accuracy-dominated, meaning there exists a conditionalization plan that is at least as accurate in all possible worlds and strictly more accurate in some. Unlike the Greaves-Wallace expected-accuracy argument, this dominance argument does not require that the partition of possible evidence be known in advance, making it applicable in cases of unanticipated evidence.

  RELEVANCE: Establishes a stronger accuracy-theoretic argument for conditionalization than Greaves and Wallace, but one that still assumes evidence is exogenous. For the profiling project, this paper sets up the key contrast: even the strongest possible accuracy-based defense of conditionalization presupposes that the evidence partition is determined independently of the agent's beliefs and actions. When evidence selection is endogenous to prior beliefs (profiling), dominance arguments do not apply because the possible worlds in which different updating plans are compared are not neutral with respect to evidence.

  POSITION: Strongest contemporary defense of conditionalization via accuracy-dominance; illuminates where the argument fails when evidence is endogenous.
  },
  keywords = {accuracy-dominance, conditionalization, epistemic-utility, formal-epistemology, Low},
  abstract = {Abstract Epistemic decision theorists aim to justify Bayesian norms by arguing that these norms further the goal of epistemic accuracy—having beliefs that are as close as possible to the truth. The standard defense of Probabilism appeals to accuracy dominance: for every belief state that violates the probability calculus, there is some probabilistic belief state that is more accurate, come what may. The standard defense of Conditionalization, on the other hand, appeals to expected accuracy: before the evidence is in, one should expect to do better by conditionalizing than by following any other rule. We present a new argument for Conditionalization that appeals to accuracy‐dominance, rather than expected accuracy. Our argument suggests that Conditionalization is a rule of coherence: plans that conflict with Conditionalization don't just prescribe bad responses to the evidence; they also give rise to inconsistent attitudes.},
  abstract_source = {openalex},
}

@article{meacham2016ur,
  author = {Meacham, Christopher J. G.},
  title = {Ur-Priors, Conditionalization, and Ur-Prior Conditionalization},
  journal = {Ergo, an Open Access Journal of Philosophy},
  year = {2016},
  volume = {3},
  doi = {10.3998/ergo.12405314.0003.017},
  note = {
  CORE ARGUMENT: Surveys problems with standard conditionalization -- error correction, changing theory priors, evidence loss, self-locating belief -- and proposes "ur-prior conditionalization" as a more robust alternative, where agents update on their entire evidence history relative to a fixed "ur-prior" (a prior defined over centered worlds before any experience). This approach avoids many of the pathologies of standard conditionalization by making the agent's updating rule a function of their total evidence history rather than just the most recent evidence.

  RELEVANCE: Identifies conditions under which standard conditionalization fails to track truth -- relevant to the profiling project as a catalog of the framework's limitations. The "error correction" problem identified by Meacham is particularly apposite: an agent who has been updating on systematically biased evidence has no mechanism within standard conditionalization to recognize and correct this error, a structural problem that the profiling feedback loop exemplifies.

  POSITION: Comprehensive survey and proposed revision of conditionalization's standard form; identifies pathologies relevant to endogenous evidence cases.
  },
  keywords = {ur-prior, conditionalization-problems, error-correction, belief-revision, Low},
  abstract = {Conditionalization is a widely endorsed rule for updating one’s beliefs. But a sea of complaints have been raised about it, including worries regarding how the rule handles error correction, changing desiderata of theory choice, evidence loss, self-locating beliefs, learning about new theories, and confirmation. In light of such worries, a number of authors have suggested replacing Conditionalization with a different rule — one that appeals to what I’ll call “urpriors”. But different authors have understood the rule in different ways, and these different understandings solve different problems. In this paper, I aim to map out the terrain regarding these issues. I survey the different problems that might motivate the adoption of such a rule, flesh out the different understandings of the rule that have been proposed, and assess their pros and cons. I conclude by suggesting that one particular batch of proposals, proposals that appeal to what I’ll call “loaded evidential standards”, are especially promising.},
  abstract_source = {s2},
}

@article{baumgaertner2022preference,
  author = {Baumgaertner, Bert and Justwan, Florian},
  title = {The preference for belief, issue polarization, and echo chambers},
  journal = {Synthese},
  year = {2022},
  volume = {200},
  number = {5},
  doi = {10.1007/s11229-022-03880-y},
  note = {
  CORE ARGUMENT: Proposes a network-based model of issue polarization in which the central driver is a "preference for belief" -- agents prefer to hold beliefs consistent with their prior epistemic commitments, even weakly -- combined with typical epistemic network structures. Demonstrates computationally that even small initial asymmetries in belief distribution, combined with weak preference for belief, generate full-blown polarization without requiring strong mechanisms of exclusion (motivated reasoning, echo chambers). Including biased assimilation mechanisms amplifies polarization but is not its ultimate cause.

  RELEVANCE: Provides a social epistemological model of how weak prior biases, combined with ordinary epistemic community structure, generate self-reinforcing belief divergence. The model is relevant to the profiling feedback loop because it demonstrates that even mild systematic prior beliefs can, through ordinary belief revision processes over social networks, lead to entrenched and polarized views. The model bridges individual Bayesian epistemology and social belief dynamics.

  POSITION: Social epistemology network model of polarization; shows that weak individual biases generate strong collective belief entrenchment.
  },
  keywords = {belief-polarization, echo-chambers, social-epistemology, network-model, Low},
  abstract = {Some common explanations of issue polarization and echo chambers rely on social or cognitive mechanisms of exclusion. Accordingly, suggested interventions like “be more open-minded” target these mechanisms: avoid epistemic bubbles and don’t discount contrary information. Contrary to such explanations, we show how a much weaker mechanism—the preference for belief—can produce issue polarization in epistemic communities with little to no mechanisms of exclusion. We present a network model (with an empirically-validated structure) that demonstrates how a dynamic interaction between the preference for belief and common structures of epistemic communities can turn very small unequal distributions of initial beliefs into full-blown polarization. This points to a different class of explanations, one that emphasizes the importance of the initial spread of information. We also show how our model complements extant explanations by including a version of biased assimilation and motivated reasoning—cognitive mechanisms of exclusion. We find that mechanisms of exclusion can exacerbate issue polarization, but may not be the ultimate root of it. Hence, the recommended interventions suggested by extant literature is expected to be limited and the problem of issue polarization to be even more intractable.},
  abstract_source = {s2},
}

@incollection{sampson1995race,
  author = {Sampson, Robert J. and Wilson, William Julius},
  title = {Toward a Theory of Race, Crime, and Urban Inequality},
  booktitle = {Crime and Inequality},
  year = {1995},
  pages = {37--54},
  publisher = {Stanford University Press},
  doi = {10.1515/9781503615557-004},
  note = {
  CORE ARGUMENT: Sampson and Wilson argue that apparent racial differences in
  crime rates disappear when neighbourhood-level structural conditions --
  concentrated poverty, residential instability, and family disruption -- are
  controlled for. They introduce the concept of "social isolation," whereby
  ghetto residents are cut off from mainstream institutions, and argue that the
  structural causes of high crime rates are neighbourhood characteristics
  produced by racial segregation and deindustrialisation, not group-level
  behavioural propensities.

  RELEVANCE: This chapter is the canonical statement that poverty, not race
  per se, drives crime rates in racially identifiable communities -- the key
  structural premise of the Bayesian profiling model. It establishes that
  observed crime statistics reflect social conditions imposed by racial
  stratification rather than group membership as such, directly supporting the
  model's assumption that poverty is the causal variable.

  POSITION: Structural/poverty account -- foundational statement of the
  neighbourhood-effects tradition.
  },
  keywords = {poverty-crime-nexus, neighbourhood-effects, racial-segregation, structural-account, High, INCOMPLETE, no-abstract}
}

@article{sampson1997neighborhoods,
  author = {Sampson, Robert J. and Raudenbush, Stephen W. and Earls, Felton},
  title = {Neighborhoods and Violent Crime: A Multilevel Study of Collective Efficacy},
  journal = {Science},
  year = {1997},
  volume = {277},
  number = {5328},
  pages = {918--924},
  doi = {10.1126/science.277.5328.918},
  note = {
  CORE ARGUMENT: Using systematic social observation and multilevel modelling of
  343 Chicago neighbourhoods, Sampson, Raudenbush, and Earls show that
  "collective efficacy" -- social cohesion combined with willingness to
  intervene -- mediates the relationship between concentrated disadvantage and
  violent crime rates. Crucially, perceived disorder and crime are explained by
  collective efficacy and structural characteristics, not simply by the racial
  composition of neighbourhoods: concentrated poverty and residential instability
  drive both disorder and crime, with collective efficacy serving as the
  mechanism.

  RELEVANCE: This paper provides the empirical evidence that structural
  conditions (poverty, instability) rather than racial composition determine
  neighbourhood crime rates, supporting the Bayesian model's assumption that
  the underlying infraction rate is driven by poverty-linked social disorganisation
  rather than group identity. The multilevel design addresses the confounding
  problem between individual behaviour and neighbourhood context.

  POSITION: Structural/poverty account -- empirical demonstration of collective
  efficacy and poverty as the proximate causes of neighbourhood violence.
  },
  keywords = {collective-efficacy, neighbourhood-effects, concentrated-disadvantage, poverty-crime-nexus, High},
  abstract = {It is hypothesized that collective efficacy, defined as social cohesion among neighbors combined with their willingness to intervene on behalf of the common good, is linked to reduced violence. This hypothesis was tested on a 1995 survey of 8782 residents of 343 neighborhoods in Chicago, Illinois. Multilevel analyses showed that a measure of collective efficacy yields a high between-neighborhood reliability and is negatively associated with variations in violence, when individual-level characteristics, measurement error, and prior violence are controlled. Associations of concentrated disadvantage and residential instability with violence are largely mediated by collective efficacy.},
  abstract_source = {openalex},
}

@article{sampson2018neighbourhood,
  author = {Sampson, Robert J.},
  title = {Neighbourhood Effects and Beyond: Explaining the Paradoxes of Inequality in the Changing American Metropolis},
  journal = {Urban Studies},
  year = {2018},
  volume = {56},
  number = {1},
  pages = {3--32},
  doi = {10.1177/0042098018795363},
  note = {
  CORE ARGUMENT: Sampson synthesises thirty years of neighbourhood-effects
  research to develop a framework of "compounded deprivation": disadvantage
  accumulates across life course, geography, and generations, with racial
  inequality in neighbourhood exposure to poverty functioning as a distinct
  causal layer above and beyond individual socioeconomic status. He argues that
  concentrated poverty and racial segregation endure as structural features of
  American cities, and that spatial mobility patterns are generating new forms
  of "higher-order segregation" beyond the local neighbourhood.

  RELEVANCE: This review provides an updated synthesis of the evidence that
  racial disparities in criminal justice outcomes are mediated by neighbourhood
  structural conditions. For the Bayesian model, it supports the claim that the
  disproportionate concentration of poverty within racially defined groups is
  a structural -- not behavioural -- phenomenon, and that this structural
  concentration is reproduced across time.

  POSITION: Structural/poverty account -- review article updating the
  neighbourhood-effects programme to include life-course and spatial-mobility
  dimensions.
  },
  keywords = {neighbourhood-effects, compounded-deprivation, racial-segregation, structural-account, High},
  abstract = {American cities today are simultaneously the same and different from Wilson’s classic portrayal in The Truly Disadvantaged ([1987] 2012), first published over 30 years ago. Concentrated poverty and racial segregation endure, as do racial gaps in multiple aspects of wellbeing. But mass incarceration, the dramatic drop in violent crime, immigration, rising income segregation, the suburbanisation of poverty, and other macrosocial trends have transformed the urban scene. The paradoxical result is that cities today are both better and worse off. In this paper, I put forth a unifying framework on persistence and change in urban inequality, highlighting a theory of neighbourhood effects and the higher-order structure of the contemporary metropolis. I apply this analytic framework to examine: (1) neighbourhood inequality as an important driver and mediator of urban transformation; (2) racial disparities across the life course in compounded deprivation, poisoned development, and intergenerational mobility; and (3) how everyday spatial mobility beyond the local neighbourhood is producing new forms of social isolation and higher-order segregation. I conclude with a challenge to dominant policy perspectives on urban racial inequality.},
  abstract_source = {s2},
}

@article{sampson2025frontiers,
  author = {Sampson, Robert J.},
  title = {Frontiers of Research on Racial Inequalities in Criminal Justice},
  journal = {RSF: The Russell Sage Foundation Journal of the Social Sciences},
  year = {2025},
  volume = {11},
  number = {3},
  pages = {1--21},
  doi = {10.7758/rsf.2025.11.3.01},
  note = {
  CORE ARGUMENT: Sampson identifies three organising themes for current research
  on racial inequality in criminal justice: the temporal and spatial contingency
  of racial disparities (how social change reshapes them); the interconnection
  between crime rates, criminal justice contact, and punishment (emphasising
  that crime rates and enforcement decisions must be analysed jointly); and
  structural racial inequality that accumulates across the life course beyond
  individual episodes of bias. He calls for research that moves beyond
  documenting bias at isolated processing stages to tracing cumulative
  structural disadvantage.

  RELEVANCE: As a 2025 review, this paper establishes the current research
  frontier and confirms that the central questions animating the Bayesian
  profiling model -- how structural factors confound the racial signal in
  criminal justice statistics, and how feedback between policing and social
  conditions operates -- remain unresolved. Sampson's emphasis on the
  crime-enforcement-punishment connection directly maps to the model's feedback
  loop.

  POSITION: Structural/poverty account -- agenda-setting review identifying
  current frontiers in racial inequality research.
  },
  keywords = {racial-inequality, cumulative-disadvantage, structural-account, enforcement-feedback, High},
  abstract = {Racial disparities in contact with the criminal justice system remain a pressing concern for both scholars and the public, yet debate persists about how best to explain and reduce them. The articles in this special issue advance our understanding by evaluating research on racial bias in law enforcement, criminal justice processing, and incarceration. I highlight three unifying themes: the significance of time and place, especially how social change shapes racial inequalities; the connection between crime, criminal justice contact, and punishment, emphasizing social processes that influence both criminal behavior and legal outcomes; and structural racial inequalities that extend beyond individual bias and accumulate throughout people’s lives. Drawing from this conceptual framework and the issue’s comprehensive reviews, I outline a future research agenda to better understand—and potentially reduce—racial inequalities in criminal justice.},
  abstract_source = {s2},
}

@article{western2010incarceration,
  author = {Western, Bruce and Pettit, Becky},
  title = {Incarceration and Social Inequality},
  journal = {Daedalus},
  year = {2010},
  volume = {139},
  number = {3},
  pages = {8--19},
  doi = {10.1162/daed_a_00019},
  note = {
  CORE ARGUMENT: Western and Pettit argue that mass incarceration has created
  a new dimension of social stratification, concentrated among Black men with
  low education. They show that by 2008 roughly 37 percent of Black male
  high-school dropouts born between 1975 and 1979 had been imprisoned by their
  late thirties -- a prevalence so high that incarceration has become a
  normative life event for this group. They further show that standard labour-
  market statistics systematically undercount disadvantage because surveys
  exclude the incarcerated population, producing spurious improvements in
  measured Black-white earnings gaps.

  RELEVANCE: This paper establishes the empirical basis for the claim that a
  disproportionate share of the poor (specifically, low-education Black men)
  is concentrated within the group targeted by profiling -- the structural
  premise of the Bayesian model. It also demonstrates that statistics based on
  non-incarcerated populations systematically understate racial inequality,
  illustrating how enforcement-generated selection affects empirical inference.

  POSITION: Structural/poverty account -- foundational empirical demonstration
  of race-class stratification through mass incarceration.
  },
  keywords = {incarceration, racial-inequality, poverty, social-stratification, statistics-bias, High},
  abstract = {In the last few decades the institutional contours of American social inequality have been transformed by the rapid growth in the prison and jail population. America’s prisons and jails have produced a new social group, a group of social outcasts who are joined by the shared experience of incarceration, crime, poverty, racial minority, and low education. As an outcast group, the men and women in our prisons and jails, have little access to the social mobility available to the mainstream. Social and economic disadvantage, crystallizing in penal confinement, is sustained over the life course and transmitted from one generation to the next. This is a profound institutionalized inequality that has renewed race and class disadvantage. Still the scale and empirical details are largely an unknown story. In this paper we describe some new research outlining several of the latest trends in incarceration and their social and economic impact. Though the rate of incarceration is historically high, perhaps the most important social fact is the inequality in penal confinement, producing extraordinary rates of ∗We gratefully acknowledge Bryan Sykes, Deirdre Bloome, and Chris Muller helped conduct the research reported in this paper.},
  abstract_source = {s2},
}

@article{western2002impact,
  author = {Western, Bruce},
  title = {The Impact of Incarceration on Wage Mobility and Inequality},
  journal = {American Sociological Review},
  year = {2002},
  volume = {67},
  number = {4},
  pages = {526--546},
  doi = {10.1177/000312240206700403},
  note = {
  CORE ARGUMENT: Using the National Longitudinal Survey of Youth, Western shows
  that incarceration substantially reduces subsequent wage growth among young
  men, and that because incarceration is so prevalent among Black non-college
  men (roughly one quarter of this group were incarcerated between 1979 and
  1998), the effect of imprisonment on individual wages also increases aggregate
  racial wage inequality. The findings demonstrate a feedback mechanism: poverty
  and limited employment prospects increase incarceration risk, and incarceration
  then reduces subsequent earnings, deepening the poverty-crime nexus.

  RELEVANCE: This paper documents the reinforcing feedback between incarceration
  and labour-market marginalisation that sustains the disproportionate
  concentration of poverty among the group targeted by profiling. It establishes
  one concrete mechanism -- wage suppression -- through which criminal justice
  contact reproduces the structural conditions that generate both poverty and
  elevated policing intensity.

  POSITION: Structural/poverty account -- empirical demonstration of
  incarceration's causal role in perpetuating racial wage inequality.
  },
  keywords = {incarceration, wage-inequality, poverty-reproduction, racial-stratification, Medium},
  abstract = {A life course perspective on crime indicates that incarceration can disrupt key life transitions. Life course analysis of occupations finds that earnings mobility depends on stable employment in career jobs. These two lines of research thus suggest that incarceration reduces ex-inmates’ access to the steady jobs that usually produce earnings growth among young men. Consistent with this argument, evidence for slow wage growth among ex-inmates is provided by analysis of the National Longitudinal Survey of Youth. Because incarceration is so prevalent—one-quarter of black non-college males in the survey were interviewed between 1979 and 1998 while in prison or jail—the effect of imprisonment on individual wages also increases aggregate race and ethnic wage inequality.},
  abstract_source = {s2},
}

@article{soss2017police,
  author = {Soss, Joe and Weaver, Vesla},
  title = {Police Are Our Government: Politics, Political Science, and the Policing of Race-Class Subjugated Communities},
  journal = {Annual Review of Political Science},
  year = {2017},
  volume = {20},
  number = {1},
  pages = {565--591},
  doi = {10.1146/annurev-polisci-060415-093825},
  note = {
  CORE ARGUMENT: Soss and Weaver argue that policing in low-income minority
  communities constitutes a distinct form of governance -- what they call the
  state's "second face" -- in which coercion, surveillance, and regulation
  substitute for democratic responsiveness. They develop the concept of "race-
  class subjugated communities" (RCS communities) to capture the intersection
  of racial and economic marginality that determines the intensity of police
  contact, and argue that political scientists have systematically underattended
  to this form of state power.

  RELEVANCE: This paper provides the political-theoretical account of why
  policing resources are allocated differently to poor minority communities --
  the deployment structure that generates the differential enforcement the
  Bayesian model represents. The concept of RCS communities maps onto the
  model's assumption that the targeted group is defined by the intersection of
  poverty and racial minority status rather than by either alone.

  POSITION: Structural/poverty account -- political analysis of differential
  policing as a form of governance directed at race-class subjugated communities.
  },
  keywords = {police-governance, racial-class-subjugation, differential-enforcement, political-science, High},
  abstract = {Against the backdrop of Ferguson and the Black Lives Matter movement, we ask what the American politics subfield has to say about the political lives of communities subjugated by race and class. We argue that mainstream research in this subfield—framed by images of representative democracy and Marshallian citizenship—has provided a rich portrait of what such communities lack in political life. Indeed, by focusing so effectively on their political marginalization, political scientists have ironically made such communities marginal to the subfield's account of American democracy and citizenship. In this article, we provide a corrective by focusing on what is present in the political lives of such communities. To redress the current imbalance and advance the understandings of race and class in American politics, we argue that studies of the liberal-democratic “first face” of the state must be complemented by greater attention to the state's more controlling “second face.” Focusing on policing, we seek to unsettle the mainstream of a subfield that rarely inquires into governmental practices of social control and the ways “race-class subjugated communities” are governed through coercion, containment, repression, surveillance, regulation, predation, discipline, and violence.},
  abstract_source = {openalex},
}

@book{wacquant2009punishing,
  author = {Wacquant, Loic},
  title = {Punishing the Poor: The Neoliberal Government of Social Insecurity},
  year = {2009},
  publisher = {Duke University Press},
  doi = {10.1215/9780822392255},
  note = {
  CORE ARGUMENT: Wacquant argues that the punitive turn in American criminal
  justice after the mid-1970s is not a response to rising crime but to the
  social insecurity produced by deindustrialisation and the erosion of the
  welfare state. "Prisonfare" -- the expansion of the penal state -- and
  "workfare" -- the imposition of precarious employment -- function as
  complementary instruments for managing the postindustrial poor, disproportionately
  Black and Latino, whose labour is no longer needed by the formal economy. The
  book documents how poverty is penalised rather than addressed through social
  provision.

  RELEVANCE: Wacquant provides the political-economy account of why the
  targeted group in the profiling model -- low-income Black and Latino men -- is
  so large, and why it became concentrated in areas of intensive policing.
  The argument that criminal justice expansion is a response to poverty rather
  than crime directly supports the model's core assumption that poverty, not
  behaviour, is the structural driver of enforcement intensity.

  POSITION: Structural/poverty account -- political-economy analysis of the
  expansion of the penal state as management of racialised poverty.
  },
  keywords = {mass-incarceration, neoliberalism, prisonfare, racial-poverty, structural-account, Medium},
  abstract = {The punitive turn of penal policy in the United States after the acme of the Civil Rights movement responds not to rising criminal insecurity but to the social insecurity spawned by the fragmentation of wage labor and the shakeup of the ethnoracial hierarchy. It partakes of a broader reconstruction of the state wedding restrictive "workfare" and expansive "prisonfare" under a philosophy of moral behaviorism. This paternalist program of penalization of poverty aims to curb the urban disorders wrought by economic deregulation and to impose precarious employment on the postindustrial proletariat. It also erects a garish theater of civic morality on whose stage political elites can orchestrate the public vituperation of deviant figures—the teenage "welfare mother," the ghetto "street thug," and the roaming "sex predator"—and close the legitimacy deficit they suffer when they discard the established government mission of social and economic protection. By bringing developments in welfare and criminal justice into a single analytic framework attentive to both the instrumental and communicative moments of public policy, Punishing the Poor shows that the prison is not a mere technical implement for law enforcement but a core political institution. And it reveals that the capitalist revolution from above called neoliberalism entails not the advent of "small government" but the building of an overgrown and intrusive penal state deeply injurious to the ideals of democratic citizenship.},
  abstract_source = {s2},
}

@article{garland2023crisis,
  author = {Garland, David},
  title = {The Current Crisis of American Criminal Justice: A Structural Analysis},
  journal = {Annual Review of Criminology},
  year = {2023},
  volume = {6},
  number = {1},
  pages = {43--63},
  doi = {10.1146/annurev-criminol-030722-035139},
  note = {
  CORE ARGUMENT: Garland situates calls to defund police, end mass incarceration,
  and dismantle systemic racism within the broader political economy of the
  United States: a form of capitalism forged on the anvils of slavery and racial
  segregation that generates high levels of social disorganisation and violent
  crime, and that predisposes state authorities to adopt penal control as the
  preferred policy response. He argues that America's extraordinary rates of
  violence, incarceration, and police killing are structural features of a
  racialised political economy, not aberrations.

  RELEVANCE: Garland's structural analysis explains why concentrated poverty,
  racial segregation, and intensive policing co-evolve as features of the same
  political economy -- the macro-structural context in which the Bayesian
  feedback model operates. It helps answer the question of why the disproportionate
  concentration of poverty within racialised groups is reproduced across time.

  POSITION: Structural/poverty account -- political-economy review explaining
  mass incarceration and racialised policing as features of a distinctive
  American political economy.
  },
  keywords = {mass-incarceration, political-economy, structural-racism, violence, Medium},
  abstract = {This review situates the recent, radical challenges to American criminal justice—calls to end mass incarceration, defund the police, and dismantle systemic racism—within the broader social and economic arrangements that make the US system so distinctive and so problematic. It describes the social structures, institutions, and processes that give rise to America's extraordinary penal state—as well as to its extraordinarily high rates of homicide and social disorder—and considers what these portend for the prospect of radical change. It does so by locating American crime and punishment in the structural context of America's (always-already racialized) political economy—a distinctive set of social structures and institutional legacies that render the United States more violent, more disorderly, and more reliant on penal control than any other developed nation. Drawing on a broad range of social science research findings, it argues that this peculiar political economy—a form of capitalism and democratic governance forged on the anvils of slavery and racial segregation and rendered increasingly insecure and exclusionary in the decades following deindustrialization—generates high levels of social disorganization and criminal violence and predisposes state authorities to adopt penal control as the preferred policy response. Expected final online publication date for the Annual Review of Criminology, Volume 6 is January 2023. Please see http://www.annualreviews.org/page/journal/pubdates for revised estimates.},
  abstract_source = {s2},
}

@article{kurlychek2019cumulative,
  author = {Kurlychek, Megan C. and Johnson, Brian D.},
  title = {Cumulative Disadvantage in the American Criminal Justice System},
  journal = {Annual Review of Criminology},
  year = {2019},
  volume = {2},
  number = {1},
  pages = {291--319},
  doi = {10.1146/annurev-criminol-011518-024815},
  note = {
  CORE ARGUMENT: Kurlychek and Johnson argue that disadvantage accumulates
  across successive stages of criminal justice processing -- arrest, prosecution,
  bail, plea bargaining, sentencing -- in ways that compound across individuals'
  life courses. Each disadvantageous outcome (e.g., pretrial detention) increases
  the probability of a disadvantageous outcome at the next stage, creating
  multiplicative disadvantage rather than additive disadvantage. Racial
  disparities at early stages (policing) are thus amplified, not attenuated,
  as cases move through the system.

  RELEVANCE: Cumulative disadvantage is the amplification mechanism that the
  Bayesian model's feedback loop produces in criminal justice processing.
  Kurlychek and Johnson show that initial policing disparities are not corrected
  at downstream stages but compounded, which means that enforcement-generated
  arrest statistics systematically overstate downstream racial disparities
  beyond what initial enforcement intensity would predict.

  POSITION: Cumulative-disadvantage account -- review demonstrating compounding
  of racial disparities across criminal justice stages.
  },
  keywords = {cumulative-disadvantage, criminal-justice, racial-disparity, processing-stages, Medium},
  abstract = {Research on inequality in punishment has a long and storied history, yet the overwhelming focus has been on episodic disparity in isolated stages of criminal case processing (e.g., arrest, prosecution, or sentencing). Although theories of cumulative disadvantage exist in criminology, they are seldom adapted to account for treatment in the criminal justice system. We provide an overview of the concept of cumulative disadvantage in the life course and review evidence on the development of cumulative disadvantages across stages of the criminal justice system. In doing so, we appraise the empirical research on policing, prosecution, and the courts and consider how these largely separate bodies of scholarship are inherently connected. We conclude with a call for future research that focuses more explicitly on the ways that life-course disadvantages shape contact with the criminal justice system and how these processes work to perpetuate patterns of disadvantage within the system and in subsequent life outcomes.},
  abstract_source = {s2},
}

@article{western2021cumulative,
  author = {Western, Bruce and Davis, Jaclyn and Ganter, Flavien and Smith, Natalie},
  title = {The Cumulative Risk of Jail Incarceration},
  journal = {Proceedings of the National Academy of Sciences},
  year = {2021},
  volume = {118},
  number = {16},
  doi = {10.1073/pnas.2023429118},
  note = {
  CORE ARGUMENT: Using administrative records of all jail admissions and
  discharges in New York City from 2008 to 2017, Western and colleagues find
  that 26.8 percent of Black men and 16.2 percent of Latino men in New York
  had been jailed by age 38, compared to only 3 percent of white men. Risks of
  jail incarceration are 40 to 50 percent higher in high-poverty neighbourhoods.
  Despite New York's low jail rate relative to other major cities, the scale of
  exposure for Black and Latino men in poor neighbourhoods is strikingly high.

  RELEVANCE: This paper quantifies the cumulative burden of criminal justice
  contact borne by low-income racial minorities in a single city, demonstrating
  that intensive jail incarceration is specifically concentrated in high-poverty
  neighbourhoods -- exactly the spatial pattern the Bayesian model predicts when
  enforcement targets poor areas that are disproportionately occupied by
  minority populations.

  POSITION: Cumulative-disadvantage account -- empirical demonstration of
  concentrated jail incarceration risk in poor minority neighbourhoods.
  },
  keywords = {jail-incarceration, cumulative-risk, neighbourhood-poverty, racial-disparity, Medium},
  abstract = {Significance Research on incarceration has focused on prisons, but the scale of admissions to local jails is significantly higher. The average length of stay in jail is brief compared to imprisonment, but jail incarceration has been found to adversely affect court outcomes, earnings, and family life. Although New York has one of the lowest jail incarceration rates among large cities, over a quarter of Black men and a sixth of Latino men in the city have been jailed by age 38 y. Risks of jail incarceration are 40 to 50% higher in poor neighborhoods. Research on incarceration has focused on prisons, but jail detention is far more common than imprisonment. Jails are local institutions that detain people before trial or incarcerate them for short sentences for low-level offenses. Research from the 1970s and 1980s viewed jails as “managing the rabble,” a small and deeply disadvantaged segment of urban populations that struggled with problems of addiction, mental illness, and homelessness. The 1990s and 2000s marked a period of mass criminalization in which new styles of policing and court processing produced large numbers of criminal cases for minor crimes, concentrated in low-income communities of color. In a period of widespread criminal justice contact for minor offenses, how common is jail incarceration for minority men, particularly in poor neighborhoods? We estimate cumulative risks of jail incarceration with an administrative data file that records all jail admissions and discharges in New York City from 2008 to 2017. Although New York has a low jail incarceration rate, we find that 26.8% of Black men and 16.2% of Latino men, in contrast to only 3% of White men, in New York have been jailed by age 38 y. We also find evidence of high rates of repeated incarceration among Black men and high incarceration risks in high-poverty neighborhoods. Despite the jail’s great reach in New York, we also find that the incarcerated population declined in the study period, producing a large reduction in the prevalence of jail incarceration for Black and Latino men.},
  abstract_source = {s2},
}

@article{lee2024structural,
  author = {Lee, Hedwig},
  title = {How Does Structural Racism Operate (in) the Contemporary US Criminal Justice System?},
  journal = {Annual Review of Criminology},
  year = {2024},
  volume = {7},
  number = {1},
  pages = {233--255},
  doi = {10.1146/annurev-criminol-022422-015019},
  note = {
  CORE ARGUMENT: Lee identifies five features through which structural racism
  operates the criminal justice system: the devaluation of certain human lives,
  ubiquitous adaptation of racially biased norms to new institutional forms,
  the networked structure that links criminal justice to housing, employment,
  and health, the perceived neutrality of technically race-neutral policies,
  and temporal amnesia that obscures historical causation. She argues that
  structural racism is not an aberration but a foundational design feature.

  RELEVANCE: Lee provides the theoretical framework for understanding how racial
  disparities in criminal justice are maintained even in the absence of
  explicit racial animus -- precisely the structural mechanism the Bayesian
  model's feedback loop operates through. The "perceived neutrality" feature
  is especially relevant: statistics generated by structural racism appear
  neutral, which is what makes the confounding problem identified by Knox et al.
  and Harcourt epistemically serious.

  POSITION: Structural/poverty account -- theoretical analysis of the five
  mechanisms through which structural racism operates the criminal justice
  system.
  },
  keywords = {structural-racism, criminal-justice, racial-disparity, institutional-racism, Medium},
  abstract = {I describe how cultural and structural racism operate the entire contemporary American criminal justice system via five features: devaluation of certain human lives, ubiquitous adaptation, networked structure, perceived neutrality, and temporal amnesia. I draw from specific historical and contemporary examples in policing, courts, and corrections to further emphasize the foundational nature of racism and its role in shaping racial/ethnic inequities not just in relationship to criminal justice outcomes but also in relationship to health, economic, and social well-being. Expected final online publication date for the Annual Review of Criminology, Volume 7 is January 2024. Please see http://www.annualreviews.org/page/journal/pubdates for revised estimates.},
  abstract_source = {s2},
}

@techreport{fryer2016empirical,
  author = {Fryer, Roland},
  title = {An Empirical Analysis of Racial Differences in Police Use of Force},
  institution = {National Bureau of Economic Research},
  year = {2016},
  doi = {10.3386/w22399},
  note = {
  CORE ARGUMENT: Fryer reports that while Black and Hispanic civilians are more
  than fifty percent more likely to experience some form of non-lethal force in
  police interactions, he finds no racial differences in officer-involved
  shootings in either raw data or after controlling for contextual factors.
  He interprets this as consistent with a model in which some officers have
  discriminatory preferences but face higher expected costs from shootings.
  The paper has been widely cited as evidence against pervasive racial bias in
  lethal police force.

  RELEVANCE: This working paper is included as a methodological benchmark
  because it illustrates the selection-bias problem diagnosed by Knox et al.
  (2020): by conditioning on the sample of police encounters recorded in
  administrative data, Fryer's analysis is subject to exactly the non-
  identification problem Knox et al. formalise. The paper should be read
  alongside Knox et al. (2020) as a cautionary example of how administrative
  records can mask racial bias.

  POSITION: Contested benchmark -- frequently cited but methodologically
  challenged study claiming no racial disparity in officer-involved shootings.
  },
  keywords = {police-use-of-force, racial-disparity, enforcement-statistics, methodological-critique, Low},
  abstract = {This paper explores racial differences in police use of force.On non-lethal uses of force, blacks and Hispanics are more than fifty percent more likely to experience some form of force in interactions with police.Adding controls that account for important context and civilian behavior reduces, but cannot fully explain, these disparities.On the most extreme use of force -officerinvolved shootings -we find no racial differences in either the raw data or when contextual factors are taken into account.We argue that the patterns in the data are consistent with a model in which police officers are utility maximizers, a fraction of which have a preference for discrimination, who incur relatively high expected costs of officer-involved shootings.},
  abstract_source = {openalex},
}

@article{chouldechova2017fair,
  author = {Chouldechova, Alexandra},
  title = {Fair Prediction with Disparate Impact: {A} Study of Bias in Recidivism Prediction Instruments},
  journal = {Big Data},
  year = {2017},
  volume = {5},
  number = {2},
  pages = {153--163},
  doi = {10.1089/big.2016.0047},
  abstract = {Abstract Recidivism prediction instruments (RPIs) provide decision-makers with an assessment of the likelihood that a criminal defendant will reoffend at a future point in time. Although such instruments are gaining increasing popularity across the country, their use is attracting tremendous controversy. Much of the controversy concerns potential discriminatory bias in the risk assessments that are produced. This article discusses several fairness criteria that have recently been applied to assess the fairness of RPIs. We demonstrate that the criteria cannot all be simultaneously satisfied when recidivism prevalence differs across groups. We then show how disparate impact can arise when an RPI fails to satisfy the criterion of error rate balance.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Chouldechova proves that the three standard fairness criteria --
  calibration, false-positive parity, and false-negative parity -- cannot
  simultaneously be satisfied by any predictor whenever the base rate of the
  outcome (recidivism) differs across racial groups. Applying this impossibility
  result to COMPAS, she shows that satisfying calibration while improving
  false-positive parity for Black defendants would require the instrument to
  become miscalibrated or lower overall accuracy.

  RELEVANCE: This paper establishes the mathematical ground for the impossibility
  that lies at the heart of the domain: the feedback loop modelled in the
  project operates within a system where any choice of fairness criterion
  involves trading off other criteria. Calibration, which COMPAS claims to
  satisfy, is the criterion most compatible with the base-rate disparities that
  the feedback loop itself generates.

  POSITION: Calibration-prioritising view; foundational impossibility theorem.
  },
  keywords = {algorithmic-fairness, impossibility-theorem, COMPAS, calibration, recidivism, High}
}

@inproceedings{kleinberg2017inherent,
  author = {Kleinberg, Jon and Mullainathan, Sendhil and Raghavan, Manish},
  title = {Inherent Trade-Offs in the Fair Determination of Risk Scores},
  booktitle = {Proceedings of the 8th Innovations in Theoretical Computer Science Conference},
  year = {2017},
  pages = {43:1--43:23},
  doi = {10.4230/LIPIcs.ITCS.2017.43},
  abstract = {Recent discussion in the public sphere about algorithmic classification has involved tension between competing notions of what it means for a probabilistic classification to be fair to different groups. We formalize three fairness conditions that lie at the heart of these debates, and we prove that except in highly constrained special cases, there is no method that can satisfy these three conditions simultaneously. Moreover, even satisfying all three conditions approximately requires that the data lie in an approximate version of one of the constrained special cases identified by our theorem. These results suggest some of the ways in which key notions of fairness are incompatible with each other, and hence provide a framework for thinking about the trade-offs between them.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Simultaneously with Chouldechova, Kleinberg, Mullainathan and
  Raghavan prove that well-calibrated risk scores cannot simultaneously satisfy
  equalised odds (balance across groups in both false-positive and false-negative
  rates) unless either the base rates are equal or the predictor is perfectly
  accurate. They formalise three natural fairness conditions and demonstrate their
  pairwise incompatibility in real-world settings.

  RELEVANCE: Together with Chouldechova's paper, this establishes the core
  impossibility result that constrains all algorithmic policing systems. Because
  predictive policing feedback loops systematically change base rates -- driving
  them upward in over-policed communities -- they continuously alter the trade-off
  frontier, making simultaneous satisfaction of fairness criteria not merely
  impossible but dynamically worsening.

  POSITION: Impossibility theorem; formal computer science grounding for
  calibration--equalised-odds incompatibility.
  },
  keywords = {algorithmic-fairness, impossibility-theorem, risk-scores, equalized-odds, High}
}

@inproceedings{hardt2016equality,
  author = {Hardt, Moritz and Price, Eric and Srebro, Nathan},
  title = {Equality of Opportunity in Supervised Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  year = {2016},
  volume = {29},
  note = {
  CORE ARGUMENT: Hardt, Price and Srebro introduce the criterion of "equalised
  odds" -- requiring equal true-positive and false-positive rates across protected
  groups -- and the weaker "equality of opportunity" requiring only equal true-
  positive rates. They provide post-processing methods that adjust classifier
  thresholds to satisfy these criteria while maximising accuracy, and show
  analytically that the adjustments are compatible with optimality under certain
  conditions.

  RELEVANCE: This paper is the primary formal proposal for the fairness criterion
  most at odds with calibration (as established by Chouldechova and Kleinberg et
  al.). For the project, it represents the alternative metric that would be
  imposed if one wished to correct false-positive disparities in predictive
  policing -- a correction that the impossibility theorems show cannot be
  simultaneously achieved with calibration under unequal base rates.

  POSITION: Equalised odds view; defines the primary alternative to calibration
  in the fairness literature.
  },
  keywords = {algorithmic-fairness, equalized-odds, fairness-criterion, supervised-learning, High, INCOMPLETE}
}

@article{ensign2017runaway,
  author = {Ensign, Danielle and Friedler, Sorelle A. and Neville, Scott and Scheidegger, Carlos and Venkatasubramanian, Suresh},
  title = {Runaway Feedback Loops in Predictive Policing},
  journal = {Proceedings of the 1st ACM Conference on Fairness, Accountability, and Transparency},
  year = {2018},
  pages = {160--171},
  abstract = {Predictive policing systems are increasingly used to determine how to allocate police across a city in order to best prevent crime. Discovered crime data (e.g., arrest counts) are used to help update the model, and the process is repeated. Such systems have been empirically shown to be susceptible to runaway feedback loops, where police are repeatedly sent back to the same neighborhoods regardless of the true crime rate. In response, we develop a mathematical model of predictive policing that proves why this feedback loop occurs, show empirically that this model exhibits such problems, and demonstrate how to change the inputs to a predictive policing system (in a black-box manner) so the runaway feedback loop does not occur, allowing the true crime rate to be learned. Our results are quantitative: we can establish a link (in our model) between the degree to which runaway feedback causes problems and the disparity in crime rates between areas.},
  abstract_source = {core},
  note = {
  arXiv:1706.09847

  CORE ARGUMENT: Ensign et al. construct a mathematical model of predictive
  policing in which crime data generated by officer deployment ("discovered crime")
  feeds back into the algorithm's training data. They prove that Polya urn dynamics
  governing the feedback process cause the algorithm to concentrate patrol in
  the same neighbourhoods regardless of the true underlying crime rate -- a "runaway
  feedback loop." They show empirically that this loop occurs even with entirely
  random initial crime distributions and demonstrate interventions (using victim-
  reported crime to attenuate feedback) that mitigate but cannot eliminate the loop.

  RELEVANCE: This is the direct formal antecedent of the project's Bayesian model
  of profiling feedback. Ensign et al. prove the formal existence of exactly the
  self-reinforcing mechanism the project seeks to generalise using Bayesian
  inference and Simpson's paradox. Their distinction between "discovered crime"
  (endogenous to police behaviour) and "reported crime" (exogenous) maps onto the
  project's distinction between measured and true base rates.

  POSITION: Feedback-loop formalisation; foundational formal result for predictive
  policing bias amplification.
  },
  keywords = {predictive-policing, feedback-loop, self-reinforcing-bias, formal-model, High}
}

@article{lum2016predict,
  author = {Lum, Kristian and Isaac, William},
  title = {To Predict and Serve?},
  journal = {Significance},
  year = {2016},
  volume = {13},
  number = {5},
  pages = {14--19},
  doi = {10.1111/j.1740-9713.2016.00960.x},
  abstract = {Predictive policing systems are used increasingly by law enforcement to try to prevent crime before it occurs. But what happens when these systems are trained using biased data? Kristian Lum and William Isaac consider the evidence -- and the social consequences.},
  abstract_source = {openalex},
  note = {
  CORE ARGUMENT: Lum and Isaac apply the PREDPOL predictive policing algorithm to
  Oakland drug arrest data and then simulate what neighbourhoods would be predicted
  if drug use were distributed as indicated by self-reported survey data. They find
  that PREDPOL's predictions cluster in predominantly Black neighbourhoods even
  when the true underlying drug-use rate is uniform, because the training data
  reflects historical racially biased enforcement rather than actual drug
  prevalence. Sending officers to predicted areas then generates new arrests,
  confirming the prediction -- the feedback loop concentrates and amplifies
  disparity.

  RELEVANCE: This paper provides the paradigmatic empirical demonstration of the
  feedback mechanism the project models: arrest data trained on biased policing
  practices predicts high crime in over-policed communities, generating further
  arrests there that confirm the prediction. It directly motivates why the
  project's focus on training-data composition and base-rate estimation is the
  appropriate analytical lens.

  POSITION: Empirical feedback-loop demonstration; shows racial amplification
  through iterative prediction-deployment.
  },
  keywords = {predictive-policing, feedback-loop, PREDPOL, racial-bias, drug-enforcement, High}
}

@misc{richardson2019dirty,
  author = {Richardson, Rashida and Schultz, Jason M. and Crawford, Kate},
  title = {Dirty Data, Bad Predictions: {H}ow Civil Rights Violations Impact Police Data, Predictive Policing Systems, and Justice},
  year = {2019},
  howpublished = {New York University Law Review Online, vol.~94, pp.~192--233},
  note = {
  CORE ARGUMENT: Richardson, Schultz and Crawford document thirteen law enforcement
  agencies where predictive policing systems were trained on data known to have
  been generated by systematic civil rights violations -- unconstitutional stop-
  and-frisk programmes, coercive interrogations, fabricated arrests. They argue
  that using such "dirty data" launders past police misconduct into algorithmic
  form: discriminatory practices that would be constitutionally prohibited if
  performed by officers today are perpetuated when encoded as training features.

  RELEVANCE: The project's Bayesian model requires a source of biased training
  data to initiate the feedback loop. Richardson et al. provide the empirical and
  legal documentation of how this bias enters: policing data reflects not the
  true distribution of crime but the distribution of past police behaviour,
  including behaviour that was itself discriminatory. This paper grounds the
  "contaminated prior" that the project's model takes as its starting point.

  POSITION: Empirical-legal critique; documents the mechanism by which historical
  discrimination enters predictive systems as training data.
  },
  keywords = {predictive-policing, dirty-data, civil-rights, training-data-bias, High, INCOMPLETE}
}

@inproceedings{akpinar2021differential,
  author = {Akpinar, Nil-Jana and De-Arteaga, Maria and Chouldechova, Alexandra},
  title = {The Effect of Differential Victim Crime Reporting on Predictive Policing Systems},
  booktitle = {Proceedings of the 2021 ACM Conference on Fairness, Accountability, and Transparency},
  year = {2021},
  pages = {838--849},
  doi = {10.1145/3442188.3445877},
  abstract = {Police departments around the world have been experimenting with forms of place-based data-driven proactive policing for over two decades. Modern incarnations of such systems are commonly known as hot spot predictive policing. These systems predict where future crime is likely to concentrate such that police can allocate patrols to these areas and deter crime before it occurs. Previous research on fairness in predictive policing has concentrated on the feedback loops which occur when models are trained on discovered crime data, but has limited implications for models trained on victim crime reporting data. We demonstrate how differential victim crime reporting rates across geographical areas can lead to outcome disparities in common crime hot spot prediction models. Our analysis is based on a simulation patterned after district-level victimization and crime reporting survey data for Bogota, Colombia. Our results suggest that differential crime reporting rates can lead to a displacement of predicted hotspots from high crime but low reporting areas to high or medium crime and high reporting areas.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: While prior work (Ensign et al.) showed feedback loops from
  "discovered" crime (officer-generated arrests), Akpinar, De-Arteaga and
  Chouldechova show that models trained on victim-reported crime data also generate
  outcome disparities. Using simulation calibrated to Bogota victimisation surveys,
  they demonstrate that differential reporting rates -- lower in high-crime, under-
  served areas -- cause hotspot predictions to shift toward moderate-crime, high-
  reporting neighbourhoods, simultaneously over-policing those areas and under-
  policing genuinely high-crime zones.

  RELEVANCE: This paper extends the feedback mechanism beyond officer-generated
  data to victim-reported data, showing that the bias source is broader than
  endogenous policing. For the project, it demonstrates that the Simpson's paradox
  effect operates across multiple data-generation mechanisms, not only through the
  specific loop modelled by Ensign et al., making the Bayesian modelling approach
  correspondingly more general.

  POSITION: Empirical extension of feedback-loop analysis; shows bias from
  differential reporting, not only from patrol-generated discovery.
  },
  keywords = {predictive-policing, feedback-loop, crime-reporting, disparate-impact, High}
}

@article{barocas2016bigdata,
  author = {Barocas, Solon and Selbst, Andrew D.},
  title = {Big Data's Disparate Impact},
  journal = {California Law Review},
  year = {2016},
  volume = {104},
  number = {3},
  pages = {671--732},
  abstract = {Advocates of algorithmic techniques like data mining argue that these techniques eliminate human biases from the decision-making process. But an algorithm is only as good as the data it works with. Data is frequently imperfect in ways that allow these algorithms to inherit the prejudices of prior decision makers. In other cases, data may simply reflect the widespread biases that persist in society at large. In still others, data mining can discover surprisingly useful regularities that are really just preexisting patterns of exclusion and inequality. Unthinking reliance on data mining can deny historically disadvantaged and vulnerable groups full participation in society. This Essay examines these concerns through the lens of American antidiscrimination law -- more particularly, through Title VII's prohibition of discrimination in employment -- and shows how Title VII's business-necessity defence fails to prevent algorithmic discrimination.},
  abstract_source = {core},
  note = {
  CORE ARGUMENT: Barocas and Selbst provide a systematic legal and technical
  analysis of how data-mining techniques produce disparate impact on protected
  classes. They identify five distinct pathways: biased training data reflecting
  historical discrimination, features that serve as proxies for protected
  attributes, target variable definitions that embed discriminatory judgements,
  sample size effects that reduce accuracy for minority groups, and masking through
  overfitting. They argue that existing disparate-impact law is inadequate to
  address these mechanisms because the "business necessity" defence is easily
  satisfied by predictive accuracy.

  RELEVANCE: The proxy discrimination pathway identified by Barocas and Selbst
  directly addresses the project's concern with omitted variable bias: when a
  protected characteristic (race) is correlated with observable proxies (zip
  code, prior arrests), a model using only the proxies still effectively
  conditions on race. This is the mechanism by which profiling generates
  discriminatory feedback even in formally race-blind systems.

  POSITION: Proxy discrimination view; provides legal-technical framework for
  how disparate impact emerges from facially neutral data mining.
  },
  keywords = {proxy-discrimination, disparate-impact, training-data-bias, legal-analysis, High}
}

@inproceedings{dwork2012fairness,
  author = {Dwork, Cynthia and Hardt, Moritz and Pitassi, Toniann and Reingold, Omer and Zemel, Richard},
  title = {Fairness through Awareness},
  booktitle = {Proceedings of the 3rd Innovations in Theoretical Computer Science Conference},
  year = {2012},
  pages = {214--226},
  doi = {10.1145/2090236.2090255},
  abstract = {We study fairness in classification, where individuals are classified, e.g., admitted to a university, and the goal is to prevent discrimination against individuals based on their membership in some group, while maintaining utility for the classifier. The main conceptual contribution of this paper is a framework for fair classification comprising (1) a task-specific metric for determining the degree to which individuals are similar with respect to the classification task at hand; (2) an algorithm for maximizing utility subject to the fairness constraint, that similar individuals are treated similarly. We also present an adaptation of our approach to achieve the complementary goal of "fair affirmative action," which guarantees statistical parity while treating similar individuals as similarly as possible. Finally, we discuss the relationship of fairness to privacy.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Dwork et al. propose individual fairness -- a Lipschitz condition
  requiring that similar individuals receive similar classifier outputs, where
  similarity is measured by a task-specific metric -- as the appropriate fairness
  framework. They argue that group-level criteria (demographic parity, equalised
  odds) are insufficient because they permit highly discriminatory classifiers
  that satisfy group statistics by chance. Individual fairness requires a metric
  that captures what is morally relevant to the decision at hand.

  RELEVANCE: The individual fairness framework provides a theoretical contrast to
  the group-level impossibility theorems. For the project, Dwork et al.'s
  observation that group fairness criteria can mask individual discrimination is
  relevant to the feedback loop analysis: a system can satisfy demographic parity
  while still systematically misclassifying individuals from historically policed
  communities, because the group statistics wash out individual injustices.

  POSITION: Individual fairness view; alternative to statistical group criteria;
  foundational for subsequent debates about what fairness should measure.
  },
  keywords = {individual-fairness, fairness-criterion, metric-fairness, formal-framework, Medium}
}

@article{hedden2021statistical,
  author = {Hedden, Brian},
  title = {On Statistical Criteria of Algorithmic Fairness},
  journal = {Philosophy \& Public Affairs},
  year = {2021},
  volume = {49},
  number = {2},
  pages = {209--231},
  doi = {10.1111/papa.12189},
  abstract = {Predictive algorithms are playing an increasingly prominent role in society, being used to predict recidivism, loan repayment, job performance, and so on. With this increasing influence has come an increasing concern with the ways in which they might be unfair or biased against individuals in virtue of their race, gender, or group membership. Many purported criteria of algorithmic fairness concern statistical relationships between the algorithm's predictions and the actual outcomes, for instance requiring that the rate of false positives be equal across the relevant groups. A series of impossibility results shows that this is impossible, unless base rates are equal across the relevant groups. I argue that none of the purported criteria, except for a calibration criterion, are necessary conditions for fairness, on the grounds that they can all be simultaneously violated by a manifestly fair and uniquely optimal predictive algorithm, even when base rates are equal.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Hedden argues, via a thought experiment (two rooms with biased
  coins), that the statistical fairness criteria used in machine learning --
  demographic parity, equalised odds, predictive parity -- are all inadequate as
  criteria of fairness. The thought experiment constructs a case where a classifier
  satisfies intuitive fairness yet violates all standard metrics, or vice versa.
  He concludes that the metrics fail to track morally relevant features and that
  fairness in prediction must be grounded in independent normative theory.

  RELEVANCE: Hedden's critique establishes that the impossibility theorems do not
  resolve the normative question: one cannot simply select whichever metric is
  technically feasible and declare the system fair. This is directly relevant to
  the project's argument that feedback loops cannot be corrected by metric
  optimisation -- Hedden's analysis supports the conclusion that even a formally
  optimised system may remain substantively unfair.

  POSITION: Philosophical critique of statistical fairness criteria; argues they
  fail to capture the moral concept of fairness.
  },
  keywords = {algorithmic-fairness, fairness-criteria, philosophy, normative-theory, Medium}
}

@article{eva2022algorithmic,
  author = {Eva, Benjamin},
  title = {Algorithmic Fairness and Base Rate Tracking},
  journal = {Philosophy \& Public Affairs},
  year = {2022},
  volume = {50},
  number = {2},
  pages = {239--266},
  doi = {10.1111/papa.12211},
  note = {
  CORE ARGUMENT: Eva argues that the appropriate fairness criterion for predictive
  algorithms is base rate tracking: the algorithm's positive prediction rate for
  a group should match the true prevalence of the target outcome in that group.
  He shows this criterion entails calibration but not equalised odds, and defends
  it against Hedden's scepticism by grounding it in a probabilistic notion of
  what it means for an algorithm to "represent" individuals accurately relative to
  their reference class.

  RELEVANCE: Eva's base-rate tracking criterion is directly connected to the
  project's Bayesian model: the feedback loop corrupts the base rate data on which
  the algorithm is trained, and Eva's analysis provides a principled account of
  why miscalibration of base rates constitutes a fairness failure independent of
  any statistical criterion.

  POSITION: Base-rate-tracking view; bridges statistical calibration and
  philosophical accounts of representational accuracy.
  },
  keywords = {algorithmic-fairness, base-rate, calibration, philosophy, Medium, INCOMPLETE}
}

@article{beigang2023reconciling,
  author = {Beigang, Fabian},
  title = {Reconciling Algorithmic Fairness Criteria},
  journal = {Philosophy \& Public Affairs},
  year = {2023},
  volume = {51},
  number = {2},
  pages = {166--190},
  doi = {10.1111/papa.12233},
  abstract = {When the discussion about algorithmic fairness first started to receive academic attention, much of the debate was about criteria that use aggregate statistics of observed data to determine whether a predictive model is fair. At the center of the debate were the two criteria equalized odds and predictive parity. These criteria are (under realistic circumstances) mutually incompatible -- when one is satisfied, the other must be violated. I argue that both criteria can be modified using causal matching methods in a way that retains their intuitive appeal and renders them universally compatible.},
  abstract_source = {openalex},
  note = {
  CORE ARGUMENT: Beigang argues that the apparent incompatibility of fairness
  criteria is partly an artefact of conflating two distinct types of algorithmic
  decision-making: predictive fairness (accuracy of probability estimates) and
  allocative fairness (equitable distribution of benefits and burdens). He proposes
  a framework that distinguishes these and shows that the impossibility theorems
  are less sweeping than usually presented: calibration and equalised odds can both
  be satisfied in the predictive dimension without contradiction, since only the
  allocative use of scores generates the impossible combination.

  RELEVANCE: Beigang's distinction between predictive and allocative fairness is
  relevant to the project because the feedback loop in predictive policing
  operates across both dimensions -- the score is both a predictive claim (this
  person is likely to reoffend) and an allocative decision (this person should be
  detained). Understanding how the feedback amplifies bias requires tracking both
  dimensions simultaneously.

  POSITION: Reconciling view; argues the impossibility is less fundamental than
  claimed by distinguishing epistemic and allocative uses of prediction.
  },
  keywords = {algorithmic-fairness, impossibility-theorem, predictive-allocative-distinction, Medium}
}

@article{lippert-rasmussen2024algorithmic,
  author = {Lippert-Rasmussen, Kasper},
  title = {Algorithmic and Non-Algorithmic Fairness: {S}hould We Revise Our View of the Latter Given Our View of the Former?},
  journal = {Law and Philosophy},
  year = {2024},
  volume = {44},
  pages = {155--179},
  doi = {10.1007/s10982-024-09505-4},
  abstract = {In the US context, critics of court use of algorithmic risk prediction algorithms have argued that COMPAS involves unfair machine bias because it generates higher false positive rates of predicted recidivism for black offenders than for white offenders. In response, some have argued that algorithmic fairness concerns, either also or only, calibration across groups -- roughly, that a score assigned to different individuals by the algorithm involves the same probability of the individual having the target property across different groups of individuals -- and that, for mathematical reasons, it is virtually impossible to equalize false positive rates without impairing the calibration. I argue that in standard non-algorithmic contexts, such as hirings, we do not think that lack of calibration entails unfair bias, and that it is difficult to see why algorithmic contexts should differ fairness-wise from non-algorithmic ones in this respect.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Lippert-Rasmussen argues that calibration should not be treated
  as a necessary condition for fairness in algorithmic contexts, because analogous
  calibration requirements are not imposed in non-algorithmic hiring or admissions
  decisions. He develops a parity-of-reasoning argument: if we accept that human
  decision-making can be fair without satisfying calibration, we should not impose
  a more demanding standard on algorithms simply because they quantify uncertainty
  explicitly.

  RELEVANCE: This paper is directly relevant to the COMPAS debate, which is the
  paradigmatic case for understanding algorithmic discrimination in criminal
  justice. Lippert-Rasmussen's argument bears on the project's question of what
  "correcting" the feedback loop would require: if calibration is not strictly
  necessary, then strategies that trade calibration for lower false-positive
  disparities become normatively defensible.

  POSITION: Equalised-odds-sympathetic view; challenges calibration primacy by
  invoking parity with non-algorithmic decision-making.
  },
  keywords = {algorithmic-fairness, calibration, equalized-odds, COMPAS, statistical-discrimination, Medium}
}

@inproceedings{pleiss2017fairness,
  author = {Pleiss, Geoff and Raghavan, Manish and Wu, Felix and Kleinberg, Jon and Weinberger, Kilian Q.},
  title = {On Fairness and Calibration},
  booktitle = {Advances in Neural Information Processing Systems},
  year = {2017},
  volume = {30},
  abstract = {The machine learning community has become increasingly concerned with the potential for bias and discrimination in predictive models. This has motivated a growing line of work on what it means for a classification procedure to be "fair." In this paper, we investigate the tension between minimizing error disparity across different population groups while maintaining calibrated probability estimates. We show that calibration is compatible only with a single error constraint (i.e. equal false-negatives rates across groups), and show that any algorithm that satisfies this relaxation is no better than randomizing a percentage of predictions for an existing classifier. These unsettling findings, which extend and generalize existing results, are empirically confirmed on several datasets.},
  abstract_source = {core},
  note = {
  arXiv:1709.02012

  CORE ARGUMENT: Pleiss et al. demonstrate that equalised odds and calibration
  are incompatible under non-trivial base rate differences, extending and
  generalising Chouldechova's impossibility result. They also propose a method
  called "calibrated equalised odds" that minimises a cost-weighted combination
  of calibration error and equalised odds violation, providing a principled
  middle ground. The paper characterises precisely how much departure from
  calibration is required to achieve any given improvement in equalised odds.

  RELEVANCE: This paper fills out the technical picture of the trade-offs that
  predictive policing systems face. For the project, it quantifies the cost of
  imposing fairness corrections on a feedback-loop-biased system: reducing the
  false-positive rate disparity requires accepting miscalibration proportional
  to the base-rate disparity that the loop has generated.

  POSITION: Technical impossibility with cost-weighting proposal; bridges
  impossibility theorem and practical fairness engineering.
  },
  keywords = {algorithmic-fairness, calibration, equalized-odds, impossibility-theorem, formal-methods, Medium}
}

@article{hu2024race,
  author = {Hu, Lily},
  title = {What Is `{R}ace' in Algorithmic Discrimination on the Basis of Race?},
  journal = {Journal of Moral Philosophy},
  year = {2024},
  volume = {21},
  number = {1--2},
  pages = {1--26},
  doi = {10.1163/17455243-20234369},
  abstract = {Machine learning algorithms bring out an under-appreciated puzzle of discrimination, namely figuring out when a decision made on the basis of a factor correlated with race is a decision made on the basis of race. I argue that prevailing approaches, which are based on identifying and then distinguishing among causal effects of race, in their metaphysical timidity, fail to get off the ground. I suggest, instead, that adopting a constructivist theory of race answers this puzzle in a principled manner. On what I call a "thick constructivist" account of race, to be raced is to be socially positioned in the way indicated by a certain set of statistical regularities on the basis of particular phenotypical traits. A thick constructivist sees that acting on the basis of correlations that constitute race qua social position just is acting on the basis of race, because races just are social positions that subject their member individuals to a particular matrix of social relations.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Hu argues that the notion of race deployed in fairness literature
  is philosophically underspecified. She distinguishes biological, socially
  constructed, and causal conceptions of race, and shows that the choice of
  conception determines which interventions on race-correlated variables count as
  "using race" in an impermissible sense. In particular, she argues that
  race-as-social-cause cannot be removed from the causal structure of training
  data by removing race as an explicit feature, because race is encoded in
  neighbourhood, prior contact, and economic variables.

  RELEVANCE: Hu's analysis connects to the project's account of proxy
  discrimination: if race is a cause of differential policing, then any model
  that includes causal descendants of race (arrest history, neighbourhood)
  effectively conditions on race regardless of whether the race variable is
  included. This is the mechanism by which profiling self-reinforces through
  apparently race-neutral features.

  POSITION: Causal-structural critique of race-removal as a fairness remedy;
  philosophical analysis of what race means in algorithmic contexts.
  },
  keywords = {race, proxy-discrimination, algorithmic-fairness, philosophy, social-construction, Medium}
}

@article{hellman2020measuring,
  author = {Hellman, Deborah},
  title = {Measuring Algorithmic Fairness},
  journal = {Virginia Law Review},
  year = {2020},
  volume = {106},
  number = {4},
  pages = {811--866},
  note = {
  CORE ARGUMENT: Hellman argues that none of the standard formal fairness metrics
  captures what is morally wrong with algorithmic discrimination. Drawing on her
  general theory of discrimination, she contends that algorithmic unfairness
  consists in demeaning treatment -- treating people as if they were less morally
  important -- rather than in any particular pattern of false-positive or false-
  negative rates. She examines COMPAS and concludes that calibration cannot ground
  a defence against the charge of discrimination because it does not address the
  demeaning function of the predictions.

  RELEVANCE: Hellman's normative framework provides a philosophical foundation for
  why the feedback loop described in the project constitutes injustice: it is not
  merely that statistical metrics are violated, but that individuals from over-
  policed communities are treated as having higher prior probability of guilt
  simply because of community membership, a form of demeaning treatment the
  project's model formalises.

  POSITION: Demeaning-treatment view; challenges the adequacy of statistical
  fairness measures and grounds discrimination analysis in intrinsic moral dignity.
  },
  keywords = {algorithmic-fairness, demeaning-treatment, discrimination, COMPAS, legal-philosophy, Medium, INCOMPLETE}
}

@article{babic2023algorithmic,
  author = {Babic, Boris and Johnson King, Zoe},
  title = {Algorithmic Fairness and Resentment},
  journal = {Philosophical Studies},
  year = {2023},
  volume = {182},
  number = {1},
  pages = {87--119},
  doi = {10.1007/s11098-023-02006-5},
  note = {
  CORE ARGUMENT: Babic and Johnson King develop a theory of algorithmic fairness
  grounded in the reactive attitude of resentment. Drawing on Strawsonian moral
  psychology and Becker's economics of discrimination, they argue that an
  algorithm is fair if and only if those subject to it have no warranted
  resentment towards the decision-maker. They apply this to calibration versus
  false-positive-parity debates and argue that resentment can be warranted by
  either type of error depending on which party bears the cost.

  RELEVANCE: The resentment-based framework provides a novel normative lens for
  evaluating the feedback loop: if the initial biased training data causes false-
  positive errors concentrated among one group, members of that group have
  warranted resentment, and the algorithm's subsequent iterations perpetuate and
  amplify that grievance. The framework connects the formal impossibility results
  to individual moral standing.

  POSITION: Resentment-based fairness theory; bridges individual moral psychology
  and statistical group criteria.
  },
  keywords = {algorithmic-fairness, resentment, reactive-attitudes, philosophy, Medium, INCOMPLETE}
}

@inproceedings{chapman2022datadriven,
  author = {Chapman, Adrian and Grylls, Phil and Ugwudike, Pamela and Gammack, Diane and Ayling, Jacqui},
  title = {A Data-Driven Analysis of the Interplay between Criminological Theory and Predictive Policing Algorithms},
  booktitle = {2022 ACM Conference on Fairness Accountability and Transparency},
  year = {2022},
  pages = {36--45},
  doi = {10.1145/3531146.3533071},
  abstract = {Previous studies have focused on the biases and feedback loops that occur in predictive policing algorithms. These studies show how systemically and institutionally biased data leads to these feedback loops when predictive policing algorithms are applied in real life. We take a step back, and show that the choice in algorithm can be embedded in a specific criminological theory, and that the choice of a model on its own even without biased data can create biased feedback loops. By synthesizing "historical" data, in which we control the relationships between crimes, location and time, we show that the current predictive policing algorithms create biased feedback loops even with completely random data. The study also found that multidisciplinary analysis of such systems is vital for uncovering these issues and shows that any study of equitable AI should involve a systematic and holistic analysis of their design rationalities.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Chapman et al. show that the choice of algorithm architecture
  encodes particular criminological assumptions, and that these assumptions
  generate biased feedback loops even when trained on completely random synthetic
  data with no historical bias. They argue that hotspot algorithms based on
  self-exciting point processes (like Hawkes processes) structurally assume
  crime clustering, which causes patrol to concentrate regardless of the actual
  crime distribution. The bias is therefore built into the algorithmic design
  choice, not merely into the training data.

  RELEVANCE: This paper extends the feedback loop analysis in a way directly
  relevant to the project: the self-reinforcing bias is not solely a property of
  contaminated training data (as Richardson et al. argue) but partly a structural
  consequence of the model architecture. For the project's Bayesian model, this
  raises the question of whether Bayesian updating itself encodes assumptions that
  amplify bias independently of the prior.

  POSITION: Structural algorithmic design critique; shows feedback loops emerge
  from architectural choices, not only from biased data.
  },
  keywords = {predictive-policing, feedback-loop, algorithmic-design, criminological-theory, Low}
}

@article{hellman2024bigdata,
  author = {Hellman, Deborah},
  title = {Big Data and Compounding Injustice},
  journal = {Journal of Moral Philosophy},
  year = {2024},
  volume = {21},
  number = {1--2},
  pages = {62--83},
  doi = {10.1163/17455243-20234373},
  abstract = {This article argues that the fact that an action will compound a prior injustice counts as a reason against doing the action. I call this reason The Anti-Compounding Injustice principle. Compounding injustice and this principle are likely to be relevant when analyzing the moral issues raised by "big data" and its combination with the computational power of machine learning and artificial intelligence. Past injustice can infect the data used in algorithmic decisions in two distinct ways. Sometimes prior injustice undermines the accuracy of the data itself. Other times, past injustice produces real-world differences among people with regard to skills, health, wealth, and other traits that employers, lenders, and others seek to measure. When decisions are based on accurate data that itself results from prior injustice, these decisions can also compound injustice.},
  abstract_source = {s2},
  note = {
  CORE ARGUMENT: Hellman argues that big data applications compound injustice
  when they rely on data that itself reflects patterns of historical discrimination.
  When algorithms trained on such data inform consequential decisions, they do not
  merely replicate past wrongs but escalate them because automated decisions are
  applied at scale and are more difficult to contest than human decisions.

  RELEVANCE: This paper provides direct normative support for the project's
  argument that the feedback loop constitutes an injustice beyond the initial
  discriminatory profiling: each iteration of the loop applies the compounded
  injustice to a new cohort, and automation at scale removes the individual
  override mechanisms that might partially correct human bias.

  POSITION: Compounding injustice view; extends Hellman's discrimination theory
  to iterative big-data systems.
  },
  keywords = {big-data, algorithmic-bias, historical-discrimination, compounding-injustice, Low}
}

