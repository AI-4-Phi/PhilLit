@article{lever2005why,
  author = {Lever, Annabelle},
  title = {Why Racial Profiling Is Hard to Justify: A Response to Risse and Zeckhauser},
  journal = {Philosophy \& Public Affairs},
  year = {2005},
  volume = {33},
  number = {1},
  pages = {94--110},
  doi = {10.1111/j.1088-4963.2005.00026.x},
  note = {
  CORE ARGUMENT: Lever argues that Risse and Zeckhauser underestimate both the epistemic uncertainty of the statistical base rates they rely on and the moral significance of the expressive harm that profiling inflicts on its targets. She contends that even under their own consequentialist framing, the costs -- including damage to community trust, diminished police cooperation, and the dignitary harm of being treated as a suspect on the basis of race -- outweigh the benefits.

  RELEVANCE: Lever's response raises the damage-to-community-trust argument that connects to the project: if profiling reduces cooperation from profiled communities, it degrades the quality of crime data on which future profiling decisions rest, creating a feedback mechanism at the social level that mirrors the statistical feedback modelled by the project.

  POSITION: Anti-profiling, combined consequentialist-dignitary critique of Risse and Zeckhauser.
  },
  keywords = {racial-profiling, dignity, community-trust, epistemic-uncertainty, High},
  abstract = {In their article, “Racial Profiling,” Risse and Zeckhauser offer a qualified defense of racial profiling in a racist society, such as the contemporary United States of America. It is a qualified defense, because they wish to distinguish racial profiling as it is, and as it might be, and to argue that while the former is not justified, the latter might be. Racial profiling as it is, they recognize, is marked by police abuse and the harassment of racial minorities, and by the disproportionate use of race in profiling1. These, on their view, are unjustified. But, they contend, this does not mean that all forms of racial profiling are unjustified, even in a racist society, or that one has to be indifferent to the harms of racism to believe that this is so. Indeed, one of the aims of their article is to show that racial profiling, suitably qualified, “is consistent with support for far-reaching measures to decrease racial inequities and inequality” (p. 134), and so to challenge the assumption that “arguments in support of profiling can speak only to those who callously disregard the disadvantaged status of racial minorities.” [First paragraph]},
  abstract_source = {openalex},
}

@article{lever2007whats,
  author = {Lever, Annabelle},
  title = {What's Wrong with Racial Profiling? Another Look at the Problem},
  journal = {Criminal Justice Ethics},
  year = {2007},
  volume = {26},
  number = {1},
  pages = {20--28},
  doi = {10.1080/0731129x.2007.9992208},
  note = {
  CORE ARGUMENT: Lever extends her critique of racial profiling by arguing that the practice is wrong not merely because its consequentialist costs outweigh benefits, but because it violates a fundamental principle of democratic political equality: citizens should not face increased suspicion and surveillance on the basis of immutable characteristics that are irrelevant to individual conduct.

  RELEVANCE: Provides the democratic-equality framing of anti-profiling arguments, establishing that the moral wrong persists even if the epistemic accuracy critique (which the project advances) were somehow answered. This supports the project's claim that the feedback mechanism exposes both an epistemic and an independent moral failure.

  POSITION: Anti-profiling, democratic-equality and political-autonomy critique.
  },
  keywords = {racial-profiling, democratic-equality, political-autonomy, High},
  abstract = {According to Mathias Risse and Richard Zeckhauser, racial profiling can be justified in a society, such as the contemporary United States, where the legacy of slavery and segregation is found in lesser but, nonetheless, troubling forms of racial inequality. Racial profiling, Risse and Zeckhauser recognize, is often marked by police abuse and the harassment of racial minorities and by the disproportionate use of race in profiling. These, on their view, are unjustified. But, they contend, this does not mean that all forms of racial profiling are unjustified; nor, they claim, need one be indifferent to the harms of racism in order to justify racial profiling. In fact, one of the aims of their paper is to show that racial profiling, suitably understood, “is consistent with support for far-reaching measures to decrease racial inequities and inequality.”2 Hence, one of their most striking claims, in an original and provocative paper, is that one can endorse racial profiling without being in any way indifferent to the disadvantaged status of racial minorities. [First paragraph]},
  abstract_source = {openalex},
}

@article{risse2007reply,
  author = {Risse, Mathias},
  title = {Racial Profiling: A Reply to Two Critics},
  journal = {Criminal Justice Ethics},
  year = {2007},
  volume = {26},
  number = {1},
  pages = {4--19},
  doi = {10.1080/0731129x.2007.9992207},
  note = {
  CORE ARGUMENT: Risse responds to Lever and Lippert-Rasmussen, defending his original position that profiling can be epistemically and morally justified under specified conditions, while conceding that race should rarely be used as a decisive factor and that institutional safeguards against abuse are essential.

  RELEVANCE: The reply clarifies the pro-profiling position's dependence on accurate base-rate statistics, which the Bayesian feedback model shows to be systematically corrupted when differential sampling rates are used. The project thus challenges Risse's response at its epistemic core.

  POSITION: Pro-profiling, actuarial defence with concessions.
  },
  keywords = {racial-profiling, pro-profiling, statistical-discrimination, Medium},
  abstract = {I Background In an earlier essay, Racial Profiling, Richard Zeckhauser and I sought to delineate the shape of the moral debate about profiling, to provide conceptual clarification, and to think through some arguments. (1) Since then, Annabelle Lever and Kasper Lippert-Rasmussen have offered thoughtful responses to our article, questioning some of its central points. (2) Although both of them offer insights that advance this debate (some of which we will adopt), this essay aims to defend the main arguments of Racial Profiling. Because is a pejorative term that was introduced to criticize police practices, one needs to be careful in stating what is being assessed morally. Three issues are often confused. The first concerns the use of race as an information-carrier for investigative purposes; the second concerns police abuse; and the third concerns the disproportionate use of race in profiling. (3) Often, cases that generate discussion of profiling involve obvious instances of police abuse, or of overuse of race, that render superfluous reflection on conditions under which race might be a legitimate feature of police tactical decision making. It may be true that, given current conditions, it is impossible to use race as an information carrier without encountering massive problems of police abuse. Yet even if this is So, an investigation into conditions under which race could in principle be used is worth our while, in order to understand what are good and bad reasons for or against doing so. Our concern, then, is to assess the use of race as an information carrier in police investigations. We define racial profiling as any police-initiated action that relies on the race, ethnicity, or national origin and not merely on the behavior of an individual. We ask: Are such actions justified under conditions that could plausibly arise? (It is in this sense that we ask about the of profiling.) Unlike other definitions of profiling, (4) ours leaves it open whether there are such circumstances. Providing the kind of conceptual clarification summarized in this paragraph was one of our main motivations in Racial Profiling. I cannot overemphasize the importance of one point that follows from this: when we offer reasons for using race in police tactics, we should not be taken to offer reasons in support of as it tends to be understood, say, by many journalists, that is, without the kind of distinction of various issues that we have provided. is peculiar in two ways that make an assessment of its legitimacy different from such assessments in other contexts, especially employment discrimination. First, we are concerned with a fundamental public good (security), and second, situations in which profiling will be used are those in which investigators must make quick decisions about (say) whom to search, or in which large numbers of people are involved--situations, that is, in which not much information is accessible other than an individual's appearance. In other cases (for example, hiring or admissions) more information is available. These two points need to be kept in mind in what follows. The reason why profiling poses a serious moral problem is precisely because of these points. Readers who would want to reject the argument in Racial Profiling because they think it licenses conclusions about other scenarios they take to be clearly unwarranted should keep in mind that the presence of these two points will often block such inferences. There is a range of different situations for which questions about the legitimacy of the use of race arise, and whose particular features require equally particular consideration. To mention three paradigmatic cases: there are scenarios in which police employ race and ethnicity in seeking to apprehend individuals who have committed specific crimes; there is racial, ethnic, or nationality screening at airports, widely discussed after 9/11; and there are investigations on highways that rely in part on racial criteria and have as their goal the interception of drug traffic and investigations on streets that have as their goal the discovery of illegal weapons. …},
  abstract_source = {openalex},
}

@article{harcourt2004rethinking,
  author = {Harcourt, Bernard E.},
  title = {Rethinking Racial Profiling: A Critique of the Economics, Civil Liberties, and Constitutional Literature, and of Criminal Profiling More Generally},
  journal = {University of Chicago Law Review},
  year = {2004},
  volume = {71},
  pages = {1275--1381},
  doi = {10.2139/ssrn.471901},
  note = {
  CORE ARGUMENT: Harcourt argues that the standard economic efficiency
  argument for racial profiling -- that concentrating police resources on high-
  offending groups reduces crime -- contains a fundamental error: it ignores
  the "ratchet effect" whereby profiling generates higher detected crime in
  profiled communities (because more people are searched), which then justifies
  further profiling, while systematically underestimating crime in non-profiled
  communities. Profiling thus corrupts the very statistics used to justify it.
  He also shows that profiling affects deterrence asymmetrically across groups,
  further distorting the empirical record.

  RELEVANCE: This is the core analytical paper on the feedback loop between
  profiling and statistics that the Bayesian model formalises. Harcourt
  identifies the mechanism -- selective surveillance generates biased arrest
  statistics -- and shows why the standard justification for profiling rests on
  a logical error. The Bayesian model can be seen as providing a formal
  account of the "ratchet effect" Harcourt describes informally.

  POSITION: Enforcement-bias account -- foundational critique of actuarial
  profiling that identifies the feedback loop between enforcement intensity and
  observed crime statistics.
  },
  keywords = {racial-profiling, enforcement-feedback, ratchet-effect, actuarial-prediction, High},
  abstract = {New data on highway stops and searches from across the country have spawned renewed debate over racial profiling on the roads. The new data reveal consistently disproportionate searches of minority motorists, but, very often, an equal or lower general success rate associated with those searches. Harcourt argues that the key question is not whether racial profiling maximizes the success rate of searches but rather the conditions under which using race in policing is justifiable, and that the ratchet effect -- by which profiling produces higher detected crime in profiled communities -- is likely to increase overall crime costs and is constitutionally problematic.},
  abstract_source = {core},
}

@book{harcourt2006against,
  author = {Harcourt, Bernard E.},
  title = {Against Prediction},
  publisher = {University of Chicago Press},
  year = {2006},
  doi = {10.7208/chicago/9780226315997.001.0001},
  note = {
  CORE ARGUMENT: Harcourt develops his sustained argument against actuarial prediction in the criminal justice system -- sentencing, policing, and parole decisions -- arguing that relying on group membership to predict individual behaviour is epistemically flawed because it produces ratchet effects that undermine the predictive accuracy of the profiling instrument over time, and morally objectionable because it treats individuals as members of categories rather than as authors of their own acts.

  RELEVANCE: The book provides the most extensive philosophical and empirical grounding for the claim that profiling produces self-undermining feedback effects. The Bayesian model that the project develops formalises the core mechanism Harcourt describes qualitatively, and adds the specific Simpson's-paradox analysis of poverty confounding.

  POSITION: Anti-profiling, actuarial-prediction critique grounded in empirical and moral argument.
  },
  keywords = {racial-profiling, actuarial-justice, feedback-loop, ratchet-effect, book, High, INCOMPLETE, no-abstract}
}

@article{lippertrasmussen2006racial,
  author = {Lippert-Rasmussen, Kasper},
  title = {Racial Profiling Versus Community},
  journal = {Journal of Applied Philosophy},
  year = {2006},
  volume = {23},
  number = {2},
  pages = {191--205},
  doi = {10.1111/j.1468-5930.2006.00326.x},
  note = {
  CORE ARGUMENT: Lippert-Rasmussen argues that racial profiling causes a specific form of harm to the profiled community -- not merely to individual targets -- by conveying the message that members of the community are collectively suspected and by eroding the social trust and solidarity that communities require. He distinguishes this communal harm from standard individual-rights violations.

  RELEVANCE: The communal-harm analysis complements the project's feedback model: profiling not only generates biased statistics but also degrades the social relations and information flows that would enable accurate assessment of underlying risk factors, including poverty.

  POSITION: Anti-profiling, communitarian and relational critique.
  },
  keywords = {racial-profiling, community-harm, social-trust, High},
  abstract = {abstract A police technique known as racial profiling draws on statistical beliefs about crime rates in racial groups. Supposing that such beliefs are true, and that racial profiling is effective in fighting crime, is such profiling morally justified? Recently, Risse and Zeckhauser have explored the racial profiling of African‐Americans and argued that justification is forthcoming from a utilitarian as well as deontological point of view. Drawing on criticisms made by G. A. Cohen of the incentives argument for inequality, I argue that, assuming that crime rates between different racial groups would converge in the absence of racial discrimination and unjust inequality, racial profiling is comprehensively unjustified. I also explain that, because Risse and Zeckhauser simply compare the status quo with an outcome that differs from it only in respect of the practice of racial profiling, they fail to show that such profiling is non‐comprehensively justified. And, exploring the problem from the point of view of a deontological concern for fairness, I identify a number of situations in which it would be non‐comprehensively unjustified to implement racial profiling (as well as some in which it might be non‐comprehensively unjustified not to implement racial profiling).},
  abstract_source = {openalex},
}

@article{lippertrasmussen2010we,
  author = {Lippert-Rasmussen, Kasper},
  title = {{``We Are All Different''}: Statistical Discrimination and the Right to Be Treated as an Individual},
  journal = {The Journal of Ethics},
  year = {2010},
  volume = {15},
  number = {1-2},
  pages = {47--59},
  doi = {10.1007/s10892-010-9095-6},
  note = {
  CORE ARGUMENT: Lippert-Rasmussen examines whether statistical discrimination violates a right to be treated as an individual rather than as a member of a group. He concludes that such a right is difficult to ground in standard deontological or consequentialist frameworks, but that statistical discrimination can nonetheless be wrong because it tends to reinforce and entrench unjust background social inequalities.

  RELEVANCE: This paper's analysis of how statistical discrimination compounds background injustice maps directly onto the project: when race is used as a proxy for poverty-driven risk, the background inequality (that the minority group contains a disproportionate share of the poor) is laundered into a nominally race-based inference, compounding structural disadvantage.

  POSITION: Critical-analytical position on the individual-right objection to statistical discrimination.
  },
  keywords = {statistical-discrimination, individual-rights, background-injustice, Medium, INCOMPLETE, no-abstract}
}

@book{lippertrasmussen2013born,
  author = {Lippert-Rasmussen, Kasper},
  title = {Born Free and Equal?},
  publisher = {Oxford University Press},
  year = {2013},
  doi = {10.1093/acprof:oso/9780199796113.001.0001},
  note = {
  CORE ARGUMENT: Lippert-Rasmussen's systematic philosophical treatment of discrimination analyses its nature, wrongness conditions, and relationship to equality. He distinguishes direct from indirect discrimination, statistical from individual-based inferences, and intentional from non-intentional forms, arguing that wrongness is a function of whether the discriminating act unfairly disadvantages on protected grounds rather than a function of the mental states of the discriminator.

  RELEVANCE: Provides the theoretical framework for classifying the type of discrimination involved when poverty confounds race: the profiling practice indirectly discriminates against the racial group by using a correlated characteristic (group membership as a poverty proxy) to impose differential treatment.

