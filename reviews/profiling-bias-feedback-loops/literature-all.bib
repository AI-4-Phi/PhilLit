}

@article{mogensen2017cumulative,
  author = {Mogensen, Andreas},
  title = {Racial Profiling and Cumulative Injustice},
  journal = {Philosophy and Phenomenological Research},
  year = {2017},
  volume = {98},
  number = {2},
  pages = {452--477},
  doi = {10.1111/phpr.12451},
  note = {
  CORE ARGUMENT: Mogensen argues that the wrongness of racial profiling is a function not only of the individual interactions it involves but of the cumulative burden it places on profiled groups across their lives and across social settings. A policy that might seem proportionate in any single instance becomes unjust when its aggregate burden over time and space is computed against the background of existing racial disadvantage.

  RELEVANCE: The cumulative-injustice argument has direct application to the feedback-loop scenario: each profiling interaction produces marginal harm to the profiled individual, but the model shows that the aggregate effect of the feedback mechanism is to systematically entrench and worsen the structural disadvantage of the group, making the cumulative injustice much larger than the sum of individual incidents.

  POSITION: Cumulative-injustice and aggregate-harm theory of profiling's wrongness.
  },
  keywords = {racial-profiling, cumulative-injustice, aggregate-harm, feedback-loop, High},
  abstract = {This paper tries to explain why racial profiling involves a serious injustice and to do so in a way that avoids the problems of existing philosophical accounts. An initially plausible view maintains that racial profiling is pro tanto wrong in and of itself by violating a constraint on fair treatment that is generally violated by acts of statistical discrimination based on ascribed characteristics. However, consideration of other cases involving statistical discrimination suggests that violating a constraint of this kind may not be an especially serious wrong in and of itself. To fully capture the significant wrong that occurs when racial profiling is targeted at black Americans or other similarly situated groups, it is argued that we should appeal to the idea that this basic injustice is exacerbated when it forms part of a larger pattern of similar actions that collectively realize a state of cumulative injustice.},
  abstract_source = {openalex},
}

@article{bouhabib2011racial,
  author = {Bou-Habib, Paul},
  title = {Racial Profiling and Background Injustice},
  journal = {The Journal of Ethics},
  year = {2010},
  volume = {15},
  number = {1-2},
  pages = {33--46},
  doi = {10.1007/s10892-010-9091-x},
  note = {
  CORE ARGUMENT: Bou-Habib argues that racial profiling is wrong not primarily as a freestanding violation but as an act that compounds background social injustice -- specifically racial inequality in poverty and socioeconomic opportunity. Profiling is objectionable because it converts existing structural disadvantage into additional criminal-justice burdens, deepening the injustice.

  RELEVANCE: This is the paper in the philosophical literature that most directly anticipates the project's confounding-by-poverty mechanism. Bou-Habib identifies that race is a proxy for socioeconomic disadvantage, and that using it as a policing criterion therefore punishes the socioeconomic disadvantage rather than any independent group propensity. The project provides the formal Bayesian model showing exactly how this confounding produces the false appearance of a race-crime correlation.

  POSITION: Background-injustice and confounding-by-socioeconomic-status critique of profiling.
  },
  keywords = {racial-profiling, background-injustice, poverty-confounding, statistical-discrimination, High},
  abstract = {Racial profiling appears to be morally more troubling when the racial group that is the object of the profile suffers from background injustice. This article examines two accounts of this intuition. The responsibility-based account maintains that racial profiling is morally more problematic if the higher offender rate within the profiled group is the result of social injustices for which other groups in society are responsible. The expressive harm based account maintains that racial profiling is more problematic if it makes background injustice vivid and thereby causes the profiled to feel resentment. I raise problems with both accounts and suggest a third account. On the humiliation-based account, individuals who are subjected to racial profiling in a context of background injustice are placed in a situation in which they cannot prevent appearing to onlookers in a demeaning way. © 2010 Springer Science+Business Media B.V},
  abstract_source = {core},
}

@article{deangelis2014racial,
  author = {DeAngelis, Peter},
  title = {Racial Profiling and the Presumption of Innocence},
  journal = {Netherlands Journal of Legal Philosophy},
  year = {2014},
  volume = {43},
  number = {1},
  pages = {43--58},
  doi = {10.5553/njlp/221307132014043001004},
  note = {
  CORE ARGUMENT: DeAngelis argues that racial profiling in policing -- exemplified by the NYPD's stop-and-frisk policy -- constitutes a systematic violation of the presumption of innocence. The presumption of innocence has a communicative dimension: extending it is an expression of social trust and recognition of equal standing; withholding it, as racial profiling does, expresses disrespect and social condemnation. Race-based suspicion therefore disrespects targets prior to any individual wrongdoing.

  RELEVANCE: The presumption-of-innocence framing is directly relevant to the project's concern with the ``ethics of suspicion.'' The project's Bayesian model shows that racially-indexed suspicion is not only morally objectionable but epistemically invalid: the prior probability attributed to the profiled group does not track the underlying propensity, because it is derived from a corrupted sample (differential stops) and a confounded variable (poverty).

  POSITION: Communicative theory of the presumption of innocence as grounding anti-profiling argument.
  },
  keywords = {racial-profiling, presumption-of-innocence, stop-and-frisk, disrespect, Medium},
  abstract = {I argue that a compelling way to articulate what is wrong with racial profiling in policing is to view racial profiling as a violation of the presumption of innocence. I discuss the communicative nature of the presumption of innocence as an expression of social trust and a protection against the social condemnation of being undeservingly investigated, prosecuted, and convicted for committing a crime. I argue that, given its communicative dimension, failures to extend the presumption of innocence are an expression of disrespect. I take the New York Police Department’s stop-and-frisk policy as an example of racial profiling and argue that its use of race-based forms of suspicion as reasons for making stops is a violation of the presumption of innocence. I maintain that this systemic failure to extend the presumption of innocence to profiled groups reveals the essentially disrespectful nature of the NYPD policy.},
  abstract_source = {s2},
}

@book{fricker2007epistemic,
  author = {Fricker, Miranda},
  title = {Epistemic Injustice},
  publisher = {Oxford University PressOxford},
  year = {2007},
  doi = {10.1093/acprof:oso/9780198237907.001.0001},
  note = {
  CORE ARGUMENT: Fricker introduces the concept of epistemic injustice -- harm done to someone in their capacity as a knower -- and develops two central forms: testimonial injustice (deflated credibility due to identity prejudice) and hermeneutical injustice (gaps in collective interpretive resources that disadvantage certain social groups). Both forms emerge when structural social inequalities corrupt the epistemic practices of a community.

  RELEVANCE: Fricker's framework applies to the profiling context in two ways: profiling based on race-indexed suspicion is a form of testimonial injustice (profiled individuals' denials of guilt are discounted); and the absence of a conceptual framework that captures how poverty confounds race constitutes a hermeneutical gap that the project's model addresses. The project's formal analysis of why the observed crime-rate differential is spurious is precisely the kind of critical epistemic tool Fricker envisions.

  POSITION: Framework for epistemic injustice as background theory for why profiling is epistemically vicious as well as morally wrong.
  },
  keywords = {epistemic-injustice, testimonial-injustice, hermeneutical-injustice, book, Medium},
  abstract = {Abstract Justice is one of the oldest and most central themes of philosophy, but sometimes we would do well to focus instead on injustice. In epistemology, the very idea that there is a first-order ethical dimension to our epistemic practices — the idea that there is such a thing as epistemic justice — remains obscure until we adjust the philosophical lens so that we see through to the negative space that is epistemic injustice. This book argues that there is a distinctively epistemic genus of injustice, in which someone is wronged specifically in their capacity as a knower, wronged therefore in a capacity essential to human value. The book identifies two forms of epistemic injustice: testimonial injustice and hermeneutical injustice. In doing so, it charts the ethical dimension of two fundamental epistemic practices: gaining knowledge by being told and making sense of our social experiences. As the account unfolds, the book travels through a range of philosophical problems. Thus, the book finds an analysis of social power; an account of prejudicial stereotypes; a characterization of two hybrid intellectual-ethical virtues; a revised account of the State of Nature used in genealogical explanations of the concept of knowledge; a discussion of objectification and ‘silencing’; and a framework for a virtue epistemological account of testimony. The book reveals epistemic injustice as a potent yet largely silent dimension of discrimination, analyses the wrong it perpetrates, and constructs two hybrid ethical-intellectual virtues of epistemic justice which aim to forestall it.},
  abstract_source = {openalex},
}

@book{eidelson2015discrimination,
  author = {Eidelson, Benjamin},
  title = {Discrimination and Disrespect},
  publisher = {Oxford University Press},
  year = {2015},
  doi = {10.1093/acprof:oso/9780198732877.001.0001},
  note = {
  CORE ARGUMENT: Eidelson argues that wrongful discrimination is constituted by disrespect for the individual as such: the discriminator fails to recognise the morally relevant individuality of the person and treats them as merely a member of a category. This failure of recognition is the core wrong, not the differential treatment itself nor its harmful consequences.

  RELEVANCE: Eidelson's individualism-grounded account of discrimination's wrongness challenges actuarial profiling: using race as a proxy treats individuals as instances of statistical categories, denying them the recognition of individual moral agency that grounds the presumption of innocence. This provides a non-consequentialist grounding for the project's normative conclusion.

  POSITION: Recognition-based, individualist theory of wrongful discrimination.
  },
  keywords = {discrimination, disrespect, recognition, individuality, book, Medium},
  abstract = {Abstract Discrimination, this book argues, is a form of differential treatment distinguished by its special connection to the differential ascription of some property to different people. This simple conceptual analysis of discrimination dissolves certain recurrent puzzles. It also positions us to reconsider the derivative notion of indirect discrimination (or discrimination consisting in “disparate impact”). Offering a revisionist account of that idea, the book explains why some such cases are reducible to “direct” discrimination, and why others, although morally and legally suspect, may not best be thought of as “discrimination” at all. The core of the book then argues that what makes some cases of discrimination intrinsically wrongful is that they manifest an attitude of disrespect for the personhood of those who are disfavored. The book specifies what this attitude consists in, and demonstrates how attending to its character illuminates different forms of wrongful discrimination. Focusing on the distinct requirements of respect for the equality and autonomy of persons in turn, the book explains why we condemn some cases of discrimination as strongly as we do and offers principles to guide our thinking where we are less certain. The book concludes with an extended discussion of racial profiling in law enforcement. Although profiling may not itself effectuate an attitude of basic disrespect, it contributes to a set of contingent social understandings that undermine the conditions of mutual respect. The failure to clearly separate these two lines of criticism, the book argues, has confounded popular and philosophical discussion of profiling and similar practices.},
  abstract_source = {openalex},
}

@article{maitzen1991ethics,
  author = {Maitzen, Stephen},
  title = {The Ethics of Statistical Discrimination},
  journal = {Social Theory and Practice},
  year = {1991},
  volume = {17},
  number = {1},
  pages = {23--45},
  doi = {10.5840/soctheorpract199117114},
  note = {
  CORE ARGUMENT: Maitzen provides an early systematic analysis of the ethics of using group-level statistical evidence to make inferences about individuals, arguing that statistical discrimination is morally objectionable when it fails to respect individuals as authors of their own actions rather than mere instances of a group profile, even when the statistical inference is accurate.

  RELEVANCE: Provides the foundational philosophical treatment of statistical discrimination as a form of disrespect for individual agency. The project shows that profiling fails not only this non-consequentialist standard but also the purely epistemic standard of accuracy, because the group-level statistics are themselves artifacts of the profiling practice.

  POSITION: Early deontological critique of statistical discrimination.
  },
  keywords = {statistical-discrimination, individuality, deontological-critique, Low, INCOMPLETE, no-abstract}
}

@article{williams2010risse,
  author = {Williams, Reginald},
  title = {Risse and Zeckhauser on Racial Profiling: A Reply},
  journal = {Utilitas},
  year = {2010},
  volume = {22},
  number = {2},
  pages = {228--231},
  doi = {10.1017/s0953820810000117},
  note = {
  CORE ARGUMENT: Williams argues that Risse and Zeckhauser's pro-profiling argument fails because their consequentialist calculus relies on crime statistics that are themselves products of racially biased policing practices, making the statistical justification circular: profiling is justified by crime-rate data that are generated by the profiling practice itself.

  RELEVANCE: Williams identifies the circularity that the Bayesian feedback model formalises. His argument is qualitative; the project provides the formal mechanism showing why the observed hit-rate data that appear to justify profiling are endogenous to the profiling practice and cannot serve as independent evidence for the underlying propensity hypothesis.

  POSITION: Circularity critique of the statistical justification for profiling.
  },
  keywords = {racial-profiling, circularity, endogenous-statistics, feedback-loop, Low},
  abstract = {This article criticizes Mathias Risse and Richard Zeckhauser's recent utilitarian defense of racial profiling. I use a novel thought-experiment to argue that even if a negative phenomenon could be reduced by profiling members of certain groups who happen to be disproportionately associated with it, the practice can be implausible. Specifically, I explore the possibility that in a given society, platinum blondes have a higher per capita incidence of a serious sexually transmitted disease, D . And I argue that doctors and health officials in the society would not be justified in profiling such blondes, given that there is nothing about being a platinum blonde that causes one to have D .},
  abstract_source = {openalex},
}

@article{sesardic2018racial,
  author = {Sesardic, Neven},
  title = {Is Racial Profiling a Legitimate Strategy in the Fight against Violent Crime?},
  journal = {Philosophia},
  year = {2018},
  volume = {46},
  number = {4},
  pages = {981--999},
  doi = {10.1007/s11406-018-9945-1},
  note = {
  CORE ARGUMENT: Sesardic defends a pro-profiling position on grounds of epistemic rationality: if reliable data show that members of a racial group commit violent crimes at higher rates, then law enforcement officers act rationally in using race as a factor in threat assessment. He argues that critics of profiling conflate the moral question (is profiling right?) with the epistemic question (does profiling track real crime rates?), and maintains that critics must engage the empirical data rather than dismiss the inference as inherently racist.

  RELEVANCE: Sesardic's paper is the most recent and philosophically careful defence of the pro-profiling epistemic claim. The project's formal model directly refutes it by showing that the empirical data Sesardic relies on are products of the differential sampling regime, not independent measures of propensity, and that the apparent race-crime correlation disappears when income is controlled for.

  POSITION: Pro-profiling, epistemic-rationality defence.
  },
  keywords = {racial-profiling, pro-profiling, epistemic-rationality, crime-statistics, Medium, INCOMPLETE, no-abstract}
}

@article{atenasio2020rationality,
  author = {Atenasio, David},
  title = {The Rationality of Racial Profiling},
  journal = {Criminal Justice Ethics},
  year = {2020},
  volume = {39},
  number = {3},
  pages = {183--201},
  doi = {10.1080/0731129x.2020.1853128},
  note = {
  CORE ARGUMENT: Atenasio contests the epistemic rationality of racial profiling by drawing on criminological and sociological research showing that race is a comparatively poor predictor of criminality when socioeconomic variables are controlled. He argues that officers who use race-based suspicion are making a cognitive error relative to the best available social science, which consistently finds that poverty, unemployment, and neighbourhood disadvantage explain most of the racial variance in crime statistics.

  RELEVANCE: This paper is directly continuous with the project's modelling approach: Atenasio argues, on empirical grounds, that controlling for socioeconomic status eliminates the apparent race-crime correlation, which is precisely what the project's Simpson's-paradox model formalises. The project provides the Bayesian mechanism showing why race appears to predict crime even when it does not -- differential sampling from an income-stratified population -- adding formal rigour to Atenasio's empirical claim.

  POSITION: Anti-profiling, empirical-rationality critique of race-based predictive inference.
  },
  keywords = {racial-profiling, epistemic-rationality, poverty-confounding, criminology, High},
  abstract = {A number of philosophers argue that law enforcement officers may have good reasons to racially profile suspects under certain conditions. Their conclusions rest on a claim of epistemic rationality: if members of some races are at an increased risk of criminality, then it may be rational for law enforcement officers to subject them to increased scrutiny. In this paper I contest the epistemic rationality of racial profiling by appealing to recent work in criminology and the sociology of race and crime. I argue that recent studies indicate that race is a comparatively poor baseline for judging criminality. Law enforcement officers are therefore not making a cognitive error by ignoring race to focus on other correlates of crime but are keeping up with our best social science.},
  abstract_source = {s2},
}

@article{thomsen2011art,
  author = {Thomsen, Frej Klem},
  title = {The Art of the Unseen: Three Challenges for Racial Profiling},
  journal = {The Journal of Ethics},
  year = {2010},
  volume = {15},
  number = {1-2},
  pages = {89--117},
  doi = {10.1007/s10892-010-9099-2},
  note = {
  CORE ARGUMENT: Thomsen raises three challenges for racial profiling: the ``selection problem'' (profiling selects for the profiling-specific subpopulation of the target group, not the underlying crime-prone subpopulation), the ``substitution problem'' (sophisticated criminals who belong to the profiled group substitute to avoid detection, while unsophisticated criminals in non-profiled groups escape scrutiny), and the ``institutional integrity problem'' (systematic profiling corrupts the epistemic and ethical practices of police institutions).

  RELEVANCE: The selection and substitution problems identified by Thomsen are the philosophical-discursive equivalents of the modelling problems the project addresses formally. The Bayesian feedback mechanism is precisely the mechanism by which Thomsen's selection problem propagates through time, producing the spurious race-crime correlation that appears to validate the practice.

  POSITION: Multi-objection critique of profiling addressing both epistemic and institutional dimensions.
  },
  keywords = {racial-profiling, selection-problem, substitution, institutional-integrity, Low},
  abstract = {This article analyses the moral status of racial profiling from a consequentialist perspective and argues that, contrary to what proponents of racial profiling might assume, there is a prima facie case against racial profiling on consequentialist grounds. To do so it establishes general definitions of police practices and profiling, sketches out the costs and benefits involved in racial profiling in particular and presents three challenges. The foundation challenge suggests that the shifting of burdens onto marginalized minorities may, even when profiling itself is justified, serve to prolong unjustified police practices. The valuation challenge argues that although both costs and benefits are difficult to establish, the benefits of racial profiling are afflicted with greater uncertainty than the costs, and must be comparatively discounted. Finally, the application challenge argues that using racial profiling in practice will be complicated by both cognitive and psychological biases, which together reduce the effectiveness of profiling while still incurring its costs. Jointly, it is concluded, these challenges establish a prima facie case against racial profiling, so that the real challenge consists in helping officers practice the art of the police and not see that which it is useless that they should see},
  abstract_source = {core},
}

@article{phelps1972statistical,
  author = {Phelps, Edmund S.},
  title = {The Statistical Theory of Racism and Sexism},
  journal = {The American Economic Review},
  year = {1972},
  volume = {62},
  number = {4},
  pages = {659--661},
  note = {
  CORE ARGUMENT: Phelps shows that employers who face noisy signals of individual productivity will rationally use group membership (race, sex) as an additional signal if they believe group averages differ, even with no animus. The model turns on the inverse relationship between signal reliability and the weight placed on group statistics: the noisier the test, the more the employer relies on the group prior. This explains wage differentials that persist without any taste for discrimination.

  RELEVANCE: This is the foundational formal source for the project's mechanism. The paper establishes that observing group membership can be rationally utility-maximising even when the belief about group differences is itself endogenously generated or incorrect. The project's Bayesian model extends this by showing that the employer/police officer's group prior is sustained by a selection process that prevents disconfirmation.

  POSITION: Represents the rational-Bayesian strand of statistical discrimination theory, in contrast to taste-based (Becker) accounts.
  },
  keywords = {statistical-discrimination, labour-market, rational-discrimination, foundational, High, INCOMPLETE, no-abstract}
}

@incollection{arrow1973theory,
  author = {Arrow, Kenneth J.},
  title = {The Theory of Discrimination},
  booktitle = {Discrimination in Labor Markets},
  editor = {Ashenfelter, Orley and Rees, Albert},
  publisher = {Princeton University Press},
  year = {1973},
  pages = {1--33},
  doi = {10.1515/9781400867066-003},
  note = {
  CORE ARGUMENT: Arrow distinguishes two theories of discrimination: taste-based (Becker), where discrimination reflects preferences; and statistical, where discrimination reflects informational asymmetry about worker productivity. Arrow extends the statistical account by considering how employer beliefs interact with workers' decisions to acquire qualifications, establishing a theory of equilibrium discrimination in which group-level treatment is self-sustaining through its effects on investment incentives.

  RELEVANCE: Arrow's equilibrium framing -- discrimination persisting because of how it shapes the environment that appears to justify it -- is the direct conceptual ancestor of the project's feedback loop. The insight that beliefs can be stable not because they are accurate but because they generate confirming behaviour underpins the project's Bayesian model.

  POSITION: Establishes the information-theoretic strand of discrimination theory alongside Phelps, and introduces the equilibrium perspective that Coate and Loury would formalise.
  },
  keywords = {statistical-discrimination, labour-market, equilibrium, foundational, High, INCOMPLETE, no-abstract}
}

@article{coate1993affirmative,
  author = {Coate, Stephen and Loury, Glenn C.},
  title = {Will Affirmative-Action Policies Eliminate Negative Stereotypes?},
  journal = {The American Economic Review},
  year = {1993},
  volume = {83},
  number = {5},
  pages = {1220--1240},
  note = {
  CORE ARGUMENT: Coate and Loury build a game-theoretic model with two groups and employer beliefs about workers' propensity to invest in qualifications. Multiple Nash equilibria exist: in the discriminatory equilibrium, low employer expectations rationally induce minority workers to under-invest, which in turn confirms the low expectations. The paper shows that affirmative action can eliminate the bad equilibrium but may also create a new one where employers patronise minority workers, reducing investment incentives -- a ``patronisation trap''.

  RELEVANCE: This is the canonical formal model of self-confirming discrimination in labour markets. The core mechanism -- beliefs shape incentives which shape outcomes which confirm beliefs -- is exactly the feedback loop the project models in the policing context. The paper's multiple-equilibrium structure parallels the project's claim that the discriminatory profiling equilibrium is self-stabilising even under Bayesian updating.

  POSITION: Defines the strategic-complementarity strand of statistical discrimination, where discrimination is an equilibrium phenomenon rather than a market failure from missing information.
  },
  keywords = {statistical-discrimination, self-fulfilling, equilibrium, affirmative-action, labour-market, High, INCOMPLETE, no-abstract}
}

@article{fudenberg1993self,
  author = {Fudenberg, Drew and Levine, David K.},
  title = {Self-Confirming Equilibrium},
  journal = {Econometrica},
  year = {1993},
  volume = {61},
  number = {3},
  pages = {523--545},
  doi = {10.2307/2951716},
  note = {
  CORE ARGUMENT: Fudenberg and Levine define a self-confirming equilibrium (SCE) as a strategy profile where each player's strategy is a best response to their beliefs, and beliefs are correct along the equilibrium path -- but may be wrong off path. Because off-path events never occur, players never receive data that contradicts their off-path beliefs. SCE is weaker than Nash equilibrium (it can sustain ``superstitious'' beliefs about counterfactuals) but arises naturally from any learning process where agents only observe outcomes generated by their own actions.

  RELEVANCE: SCE provides the formal game-theoretic machinery for understanding why the policing feedback loop is epistemically stable. The profiling officer who never investigates the un-profiled group never learns that the un-profiled group has a similar base rate. This paper's proof that SCE can persist even under rational Bayesian learning directly supports the project's claim that the discriminatory belief system can survive indefinitely.

  POSITION: Foundational concept in the economic theory of learning and equilibrium selection, applicable to the discrimination literature via Coate-Loury.
  },
  keywords = {self-confirming-equilibrium, learning, game-theory, belief-persistence, formal-model, High},
  abstract = {In a self-confining equilibrium, each player's strategy is a best response to his beliefs about the play of his opponents and each player's beliefs are correct along the equilibrium path of play. Thus, if a self-confirming equilibrium occurs repeatedly, no player ever observes play that contradicts his beliefs, even though beliefs about play at off-path information sets need not be correct. The authors characterize the ways in which self-confirming equilibria and Nash equilibria can differ and provide conditions under which self-confirming equilibria correspond to standard solution concepts. Copyright 1993 by The Econometric Society.},
  abstract_source = {s2},
}

@article{fudenberg2006superstition,
  author = {Fudenberg, Drew and Levine, David K.},
  title = {Superstition and Rational Learning},
  journal = {American Economic Review},
  year = {2006},
  volume = {96},
  number = {3},
  pages = {630--651},
  doi = {10.1257/aer.96.3.630},
  note = {
  CORE ARGUMENT: Fudenberg and Levine show that not all false beliefs can persist under rational learning: only ``superstitions'' whose consequences are hidden by the equilibrium path survive indefinitely. They characterise which false beliefs are immune to rational learning via the concept of subgame-confirmed Nash equilibrium, and show this requires the superstition to lie at least two steps off the equilibrium path so that it is never tested even by single deviations.

  RELEVANCE: This paper provides the conditions under which the project's key mechanism holds: discriminatory beliefs about un-policed populations survive because profiling prevents officers from taking the off-path action (investigating the un-profiled group) that would generate disconfirming evidence. The paper's conditions on persistence can be used to characterise the structure of the profiling feedback loop.

  POSITION: Extends the SCE framework to characterise which false beliefs survive rational learning, directly applicable to why profiling-induced beliefs are persistent.
  },
  keywords = {self-confirming-equilibrium, rational-learning, belief-persistence, superstition, formal-model, Medium},
  abstract = {We argue that some but not all superstitions can persist when learning is rational and players are patient, and illustrate our argument with an example inspired by the code of Hammurabi. The code specified an “appeal by surviving in the river” as a way of deciding whether an accusation was true, so it seems to have relied on the superstition that the guilty are more likely to drown than the innocent. If people can be easily persuaded to hold this superstitious belief, why not the superstitious belief that the guilty will be struck dead by lightning? We argue that the former can persist but the latter cannot by giving a partial characterization of the outcomes that arise as the limit of steady states with rational learning as players become more patient. These “subgame-confirmed Nash equilibria” have self-confirming beliefs at information sets reachable by a single deviation. According to this theory a mechanism that uses superstitions two or more steps off the equilibrium path, such as “appeal by surviving in the river,” is more likely to persist than a superstition where the false beliefs are only one step off of the equilibrium path.},
  abstract_source = {s2},
}

@article{esponda2008behavioral,
  author = {Esponda, Ignacio},
  title = {Behavioral Equilibrium in Economies with Adverse Selection},
  journal = {American Economic Review},
  year = {2008},
  volume = {98},
  number = {4},
  pages = {1269--1291},
  doi = {10.1257/aer.98.4.1269},
  note = {
  CORE ARGUMENT: Esponda introduces behavioral equilibrium for settings where agents systematically misattribute the source of selection in their data. Agents observe only outcomes that result from their actions (a selection bias), but behave as if the observed sample is representative. This generates a steady state in which beliefs are locally consistent with observed data yet globally wrong. The paper applies this to adverse selection markets but the logic extends directly to any setting where the data-generating process is endogenous to the decision rule.

  RELEVANCE: This framework formalises the mechanism at the core of the project: police officers who profile group A observe arrests only within group A, and if they fail to correct for the fact that their enforcement decisions determine the sample, they will converge to incorrect beliefs about comparative crime rates. Esponda's model shows this can constitute a stable behavioural equilibrium rather than a transient bias.

  POSITION: Extends SCE to allow for misspecified models, bridging rational learning and behavioural economics in a way directly applicable to discrimination under endogenous sampling.
  },
  keywords = {behavioral-equilibrium, adverse-selection, endogenous-sampling, belief-persistence, formal-model, High},
  abstract = {I propose a new solution concept—behavioral equilibrium—to study environments with players who are naive, in the sense that they fail to account for the informational content of other players' actions. I apply the framework to certain adverse selection settings and show that, contrary to the existing literature, the adverse selection problem is exacerbated when naive players fail to account for selection. More generally, the main distinguishing feature of the framework is that, in equilibrium, beliefs about both fundamentals and strategies are jointly restricted. Consequently, whether a behavioral bias may arise or not is determined endogenously in equilibrium. (JEL C70, D82, D83)},
  abstract_source = {openalex},
}

@article{esponda2016berk,
  author = {Esponda, Ignacio and Pouzo, Demian},
  title = {Berk-Nash Equilibrium: A Framework for Modeling Agents with Misspecified Models},
  journal = {Econometrica},
  year = {2016},
  volume = {84},
  number = {3},
  pages = {1093--1130},
  doi = {10.3982/ecta12609},
  note = {
  CORE ARGUMENT: Esponda and Pouzo generalise self-confirming equilibrium to agents with structurally misspecified models of their environment. Each agent holds a subjective model that is a restricted set of beliefs; they choose optimally given their belief; and the belief is the best fit (minimum KL divergence) to the data generated by the equilibrium strategy. Nash equilibrium and SCE are special cases with correctly specified models. With misspecification, agents can converge to beliefs that are wrong about causation even as they are maximally consistent with the data they observe.

  RELEVANCE: Directly applicable to officers who hold misspecified structural models attributing behaviour to race rather than poverty. Berk-Nash equilibrium predicts that such officers will converge to confident wrong beliefs because the misspecified race model fits the observed data better (from the officer's perspective) than the correct poverty model, particularly when poverty and race are correlated in the observed population. This gives formal support to the project's Simpson's paradox argument.

  POSITION: Most general extension of SCE; provides the formal vocabulary for agents who are systematically wrong about causation but locally consistent with observed data.
  },
  keywords = {berk-nash-equilibrium, misspecified-models, belief-persistence, causal-misattribution, formal-model, High},
  abstract = {We develop an equilibrium framework that relaxes the standard assumption that people have a correctly-specified view of their environment. Each player is characterized by a (possibly misspecified) subjective model, which describes the set of feasible beliefs over payoff-relevant consequences as a function of actions. We introduce the notion of a Berk-Nash equilibrium: Each player follows a strategy that is optimal given her belief, and her belief is restricted to be the best fit among the set of beliefs she considers possible. The notion of best fit is formalized in terms of minimizing the Kullback-Leibler divergence, which is endogenous and depends on the equilibrium strategy profile. Standard solution concepts such as Nash equilibrium and self-confirming equilibrium constitute special cases where players have correctly-specified models. We provide a learning foundation for Berk-Nash equilibrium by extending and combining results from the statistics literature on misspecified learning and the economics literature on learning in games.},
  abstract_source = {s2},
}

@article{merton1948self,
  author = {Merton, Robert K.},
  title = {The Self-Fulfilling Prophecy},
  journal = {The Antioch Review},
  year = {1948},
  volume = {8},
  number = {2},
  pages = {193},
  doi = {10.2307/4609267},
  note = {
  CORE ARGUMENT: Merton coins the concept of the self-fulfilling prophecy: a false belief that, by being acted upon, causes the very outcome it predicts. His central example is a bank run -- the false belief that a bank is insolvent causes depositors to withdraw, making the bank insolvent. He extends this to racial discrimination, showing how beliefs about group characteristics generate the social conditions that appear to confirm them, creating a closed causal loop that rational evidence-gathering cannot easily break.

  RELEVANCE: Merton's concept is the sociological archetype for the entire mechanism the project models formally. The self-fulfilling prophecy identifies the key structural feature: it is not that the initial belief is confirmed by evidence gathered independently of the belief; it is that the belief shapes the evidence. This conceptual contribution directly motivates the Bayesian formalisation.

  POSITION: Original sociological source of the self-fulfilling prophecy concept, predating the formal economic models by two decades.
  },
  keywords = {self-fulfilling-prophecy, sociology, foundational, belief-formation, High, INCOMPLETE, no-abstract}
}

@article{gelman2007analysis,
  author = {Gelman, Andrew and Fagan, Jeffrey and Kiss, Alex},
  title = {An Analysis of the {New York City} Police Department's ``Stop-and-Frisk'' Policy in the Context of Claims of Racial Bias},
  journal = {Journal of the American Statistical Association},
  year = {2007},
  volume = {102},
  number = {479},
  pages = {813--823},
  doi = {10.1198/016214506000001040},
  note = {
  CORE ARGUMENT: Gelman, Fagan and Kiss use multilevel regression to analyse over 175,000 NYPD stop-and-frisk records, finding that stops of Black and Hispanic pedestrians exceed what would be predicted by precinct-level crime rates. The paper introduces the ``benchmark problem'' -- the appropriate comparison for evaluating racial disparities in stops -- and shows that civilian complaint data and crime statistics support a finding of racial bias beyond what crime rates explain.

  RELEVANCE: This paper provides the empirical exemplar for the project's formal model. The statistical framework it uses faces the identification problem that Knox et al. subsequently formalise: if initial decisions to stop are racially biased, then crime-rate benchmarks themselves are contaminated by prior enforcement decisions. The paper illustrates both the empirical challenge and the policy significance of the feedback loop.

  POSITION: Foundational empirical analysis of racial profiling in policing, using statistical methods to detect bias in enforcement data.
  },
  keywords = {racial-profiling, stop-and-frisk, empirical, policing-bias, identification, High},
  abstract = {Recent studies by police departments and researchers confirm that police stop persons of racial and ethnic minority groups more often than whites relative to their proportions in the population. However, it has been argued that stop rates more accurately reflect rates of crimes committed by each ethnic group, or that stop rates reflect elevated rates in specific social areas, such as neighborhoods or precincts. Most of the research on stop rates and police–citizen interactions has focused on traffic stops, and analyses of pedestrian stops are rare. In this article we analyze data from 125,000 pedestrian stops by the New York Police Department over a 15-month period. We disaggregate stops by police precinct and compare stop rates by racial and ethnic group, controlling for previous race-specific arrest rates. We use hierarchical multilevel models to adjust for precinct-level variability, thus directly addressing the question of geographic heterogeneity that arises in the analysis of pedestrian stops. We find that persons of African and Hispanic descent were stopped more frequently than whites, even after controlling for precinct variability and race-specific estimates of crime participation.},
  abstract_source = {openalex},
}

@article{knox2020administrative,
  author = {Knox, Dean and Lowe, Will and Mummolo, Jonathan},
  title = {Administrative Records Mask Racially Biased Policing},
  journal = {American Political Science Review},
  year = {2020},
  volume = {114},
  number = {3},
  pages = {619--637},
  doi = {10.1017/s0003055420000039},
  note = {
  CORE ARGUMENT: Knox, Lowe and Mummolo show that if police racially discriminate at the initial contact stage (deciding whom to stop), then all subsequent administrative data -- arrests, use of force, searches -- are contaminated by post-treatment selection. Standard estimators applied to such data are statistically biased and many causal quantities are unidentified without strong untestable assumptions. They develop a bias-correction procedure and nonparametric bounds for race effects, showing that traditional estimators can dramatically underestimate or even reverse the direction of racial discrimination.

  RELEVANCE: This paper formally proves the identification problem that is at the heart of the project's feedback loop. If profiling determines the sample of encounters, then observed hit rates and arrest rates are endogenous to the profiling decision, not independent tests of it. The paper's framework provides the causal identification machinery for understanding why naive Bayesian updating from administrative records will not detect the feedback loop.

  POSITION: Formalises the selection bias underlying policing data; directly demonstrates the epistemic consequence of the feedback loop.
  },
  keywords = {policing-bias, selection-bias, identification, administrative-data, feedback-loop, causal-inference, High},
  abstract = {Researchers often lack the necessary data to credibly estimate racial discrimination in policing. In particular, police administrative records lack information on civilians police observe but do not investigate. In this article, we show that if police racially discriminate when choosing whom to investigate, analyses using administrative records to estimate racial discrimination in police behavior are statistically biased, and many quantities of interest are unidentified—even among investigated individuals—absent strong and untestable assumptions. Using principal stratification in a causal mediation framework, we derive the exact form of the statistical bias that results from traditional estimation. We develop a bias-correction procedure and nonparametric sharp bounds for race effects, replicate published findings, and show the traditional estimator can severely underestimate levels of racially biased policing or mask discrimination entirely. We conclude by outlining a general and feasible design for future studies that is robust to this inferential snare.},
  abstract_source = {s2},
}

@article{knowles2001racial,
  author = {Knowles, John and Persico, Nicola and Todd, Petra},
  title = {Racial Bias in Motor Vehicle Searches: Theory and Evidence},
  journal = {Journal of Political Economy},
  year = {2001},
  volume = {109},
  number = {1},
  pages = {203--229},
  doi = {10.1086/318603},
  note = {
  CORE ARGUMENT: Knowles, Persico and Todd develop a model of police search in which guilty motorists decide whether to carry contraband based on the probability of being searched, and officers search to maximise arrests. At equilibrium, police targeting is profit-maximising and guilt rates are equalised across groups if there is no taste discrimination. They test this model on Maryland traffic-stop data, finding equal hit rates but evidence that Black motorists face higher search rates than their estimated crime rates would justify, suggesting taste-based discrimination.

  RELEVANCE: This paper is the primary economic model of racial profiling the project's argument contests. The hit-rate test the paper proposes as an indicator of non-discrimination is subject to exactly the feedback critique Harcourt develops: equal hit rates can be consistent with discriminatory enforcement if profiling suppresses crime in the profiled group. Understanding the paper's assumptions -- including the absence of poverty as a confounder -- clarifies the contribution of the Simpson's paradox framing.

  POSITION: Defends a constrained efficiency view of racial profiling; provides the hit-rate test as an empirical benchmark.
  },
  keywords = {racial-profiling, hit-rate-test, policing, motor-vehicle-searches, efficiency, Medium},
  abstract = {African American motorists in the United States are more likely than white motorists to have their cars searched by police checking for illegal drugs and other contraband. The courts are faced with the task of deciding on the basis of traffic-stop data whether police are basing their decisions to stop cars on the race of the driver. We develop a model of law enforcement for a population with two racial types who also differ along other dimensions relevant to criminal behavior. We discuss why a simple test commonly applied by the courts is inadequate when the econometrician observes only a subset of the characteristics observed by the policemen. Next, we show how to construct a test for whether di¤erential treatment is motivated purely out of e¢ciency grounds, i.e. to maximize the number of arrests, or re‡ects racial prejudice. The test is valid even when the set of characteristics observed by the policemen are only partially observable by the econometrician. We apply the tests for discrimination to traffic stop data from Maryland. Finally, we present a},
  abstract_source = {openalex},
}

@techreport{fang2010theories,
  author = {Fang, Hanming and Moro, Andrea},
  title = {Theories of Statistical Discrimination and Affirmative Action: A Survey},
  institution = {National Bureau of Economic Research},
  year = {2010},
  doi = {10.3386/w15860},
  note = {
  CORE ARGUMENT: Fang and Moro provide a comprehensive survey of the formal theoretical literature on statistical discrimination in labour markets, covering both the Phelps signal-noise model and the Coate-Loury self-confirming expectations model. They classify mechanisms by which multiple equilibria arise, discuss comparative statics for affirmative action policies, and survey empirical tests. The survey identifies the key modelling choices -- unitary versus separating equilibrium, investment versus screening -- and their policy implications.

  RELEVANCE: This is the most complete reference source for the formal labour-market statistical discrimination literature on which the project builds. It clarifies the relationship between the Phelps-Arrow models and the Coate-Loury model, and surveys the subsequent theory that formalises the feedback mechanism. The project imports these mechanisms into a policing context.

  POSITION: Authoritative survey of formal economic models of statistical discrimination, bridging foundational and recent work.
  },
  keywords = {statistical-discrimination, survey, labour-market, affirmative-action, formal-model, Medium},
  abstract = {This chapter surveys the theoretical literature on statistical discrimination and affirmative action.This literature suggests different explanations for the existence and persistence of group inequality.This survey highlights such differences and describes in these contexts the effects of color-sighted and color-blind affirmative action policies, and the efficiency implications of discriminatory outcomes.},
  abstract_source = {openalex},
}

@article{debruin2025self,
  author = {de Bruin, Boudewijn},
  title = {Self-fulfilling testimonial injustice},
  journal = {Episteme},
  year = {2025},
  pages = {1--24},
  doi = {10.1017/epi.2025.10052},
  note = {
  CORE ARGUMENT: De Bruin introduces the concept of self-fulfilling testimonial injustice: credibility deficits assigned to members of disadvantaged groups become true through the conditions those deficits create. Drawing on economics of discrimination and social psychology, he distinguishes motivated-cognition-based from cognitive-bias-based testimonial injustice and shows how credibility deficits can become self-fulfillingly entrenched. The mechanism involves an analogue of the Coate-Loury investment trap: those whose testimony is undervalued have reduced incentives to produce high-quality testimony.

  RELEVANCE: De Bruin's concept applies self-fulfilling-prophecy logic to epistemic injustice in a way that connects the philosophy of testimony to the formal economic models of statistical discrimination. The paper provides a philosophical bridge between Miranda Fricker's framework and the feedback-loop mechanisms the project models formally, situating the profiling feedback loop within broader debates about epistemic inequality.

  POSITION: Bridges the epistemic-injustice literature (Fricker) with the economics of statistical discrimination via the self-fulfilling-prophecy mechanism.
  },
  keywords = {testimonial-injustice, self-fulfilling, epistemic-injustice, credibility, Medium},
  abstract = {Abstract This paper introduces the concept of self-fulfilling testimonial injustice: a distinctive form of epistemic injustice whereby credibility deficits become true by shaping the very conditions that sustain them. Much of the literature on testimonial injustice has rightly emphasized cases in which credibility deficits are rooted in false beliefs, themselves underwritten by ethically bad affective investments. Yet such a focus risks obscuring a structurally significant variant: namely, those credibility deficits that are rendered true through self-fulfilling mechanisms. Drawing on insights from economics and psychology, I distinguish between motivated cognition-based and cognitive bias-based testimonial injustice, which together furnish the background conditions under which self-fulfilling testimonial injustice can take hold. I develop this account by drawing on both theoretical and experimental work on labor market discrimination, which illuminates the ways in which credibility deficits may become self-fulfillingly entrenched. Finally, I explore the distinctive harms of this form of injustice, focusing on its corrosive effects on epistemic self-confidence or self-trust and epistemic self-esteem, and suggest that its insidiousness and relative invisibility render it both difficult to detect and potentially more pervasive than has hitherto been acknowledged.},
  abstract_source = {openalex},
}

@article{pager2008sociology,
  author = {Pager, Devah and Shepherd, Hana},
  title = {The Sociology of Discrimination: Racial Discrimination in Employment, Housing, Credit, and Consumer Markets},
  journal = {Annual Review of Sociology},
  year = {2008},
  volume = {34},
  number = {1},
  pages = {181--209},
  doi = {10.1146/annurev.soc.33.040406.131740},
  note = {
  CORE ARGUMENT: Pager and Shepherd review experimental and observational evidence on racial discrimination across multiple markets, synthesising audit study findings, matched-pair experiments, and analysis of administrative data. They distinguish statistical discrimination (information-based) from taste-based discrimination in explaining persistent racial gaps, and show that both operate simultaneously. They argue that the cumulative effect across multiple domains makes discrimination difficult to isolate and correct.

  RELEVANCE: This paper provides the empirical grounding for the claim that statistical discrimination is not merely a theoretical construct but an active mechanism producing racial inequalities. Its review of audit studies is directly relevant to the project's policing context because it establishes what we would observe under non-discriminatory versus statistically discriminatory versus taste-based enforcement, which is the empirical distinction the feedback loop makes invisible.

  POSITION: Empirical sociology review of discrimination mechanisms across markets; balances statistical and taste-based accounts.
  },
  keywords = {racial-discrimination, empirical-sociology, audit-studies, employment, Medium},
  abstract = {Persistent racial inequality in employment, housing, and a wide range of other social domains has renewed interest in the possible role of discrimination. And yet, unlike in the pre-civil rights era, when racial prejudice and discrimination were overt and widespread, today discrimination is less readily identifiable, posing problems for social scientific conceptualization and measurement. This article reviews the relevant literature on discrimination, with an emphasis on racial discrimination in employment, housing, credit markets, and consumer interactions. We begin by defining discrimination and discussing relevant methods of measurement. We then provide an overview of major findings from studies of discrimination in each of the four domains; and, finally, we turn to a discussion of the individual, organizational, and structural mechanisms that may underlie contemporary forms of discrimination. This discussion seeks to orient readers to some of the key debates in the study of discrimination and to provide a roadmap for those interested in building upon this long and important line of research.},
  abstract_source = {openalex},
}

@article{fryer2019empirical,
  author = {Fryer, Roland G.},
  title = {An Empirical Analysis of Racial Differences in Police Use of Force},
  journal = {Journal of Political Economy},
  year = {2019},
  volume = {127},
  number = {3},
  pages = {1210--1261},
  doi = {10.1086/701423},
  note = {
  CORE ARGUMENT: Fryer analyses administrative data from ten US police departments to estimate racial differences in police use of force. He finds that while Black and Hispanic civilians are more likely to experience non-lethal force in police interactions, there is no significant racial difference in officer-involved shootings once conditioning on police contact. This finding generated significant controversy because conditioning on police contact is a post-treatment variable if initial contact decisions are themselves racially biased.

  RELEVANCE: Fryer's paper is directly relevant to the identification problem formalised by Knox et al. The controversy about whether to condition on police contact is precisely the selection-bias problem the project addresses: once profiling determines who is stopped, conditioning on stops removes information about whether the decision to stop was itself biased. The paper illustrates how the feedback loop can be obscured in even careful empirical work.

  POSITION: Represents the contested empirical literature on racial bias in policing; illustrates the methodological stakes of the selection-bias problem.
  },
  keywords = {policing-bias, use-of-force, selection-bias, empirical, contested, Low},
  abstract = {This paper explores racial differences in police use of force. On nonlethal uses of force, blacks and Hispanics are more than 50 percent more likely to experience some form of force in interactions with police. Adding controls that account for important context and civilian behavior reduces, but cannot fully explain, these disparities. On the most extreme use of force—officer-involved shootings—we find no racial differences either in the raw data or when contextual factors are taken into account. We argue that the patterns in the data are consistent with a model in which police officers are utility maximizers, a fraction of whom have a preference for discrimination, who incur relatively high expected costs of officer-involved shootings.},
  abstract_source = {s2},
}

@book{loury2002anatomy,
  author = {Loury, Glenn C.},
  title = {The Anatomy of Racial Inequality},
  publisher = {Harvard University Press},
  year = {2003},
  doi = {10.2307/j.ctv1bzfpsb},
  note = {
  CORE ARGUMENT: Loury develops a theory of ``stigma'' as a mechanism sustaining racial inequality: negative beliefs about groups become socially encoded in institutions and practices, generating information that superficially confirms those beliefs. He distinguishes ``development effects'' (discrimination shaping actual skills and opportunities) from ``contact effects'' (discrimination occurring in exchange), and argues that the former are particularly insidious because they make the inequality appear pre-market and thus natural. The book integrates economics and social theory to explain why racial inequality is self-reproducing.

  RELEVANCE: Loury's concept of development effects -- where stereotypes shape the actual characteristics of the stereotyped group -- is the labour-market version of the feedback mechanism the project models in policing. Both involve beliefs that reshape the environment, generating data that reinforces those beliefs. The book provides theoretical and normative context for the project's formal model.

  POSITION: Combines economic theory with social theory of race; extends the statistical discrimination framework to include stigma and social reproduction.
  },
  keywords = {racial-inequality, stigma, statistical-discrimination, social-reproduction, Low, INCOMPLETE, no-abstract}
}

@article{simpson1951interpretation,
  author    = {Simpson, E. H.},
  title     = {The Interpretation of Interaction in Contingency Tables},
  journal   = {Journal of the Royal Statistical Society Series B: Statistical Methodology},
  year      = {1951},
  volume    = {13},
  number    = {2},
  pages     = {238--241},
  doi       = {10.1111/j.2517-6161.1951.tb00088.x},
  note      = {
  CORE ARGUMENT: Simpson demonstrates mathematically that a partial
  association in a two-way table can have an opposite sign to the
  marginal association once a third variable is introduced as a
  conditioning factor. The paper provides the first systematic
  treatment of what would become the eponymous paradox, showing that
  the direction of apparent effects in contingency tables is not
  preserved under aggregation.

  RELEVANCE: Furnishes the foundational mathematical description of
  the aggregation reversal that the research project exploits: the
  mechanism by which a confounded group-level statistic can misrepresent
  the underlying within-stratum association.

  POSITION: Foundational mathematical characterisation, neutral on
  causal interpretation.
  },
  keywords  = {simpsons-paradox, aggregation, contingency-tables, foundational, High},
  abstract = {Summary The definition of second order interaction in a (2 × 2 × 2) table given by Bartlett is accepted, but it is shown by an example that the vanishing of this second order interaction does not necessarily justify the mechanical procedure of forming the three component 2 × 2 tables and testing each of these for significance by standard methods.},
  abstract_source = {openalex},
}

@article{yule1903notes,
  author    = {Yule, G. Undy},
